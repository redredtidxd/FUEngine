<Window x:Class="FUEngine.GamePlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Juego" Height="400" Width="520"
        WindowStartupLocation="CenterScreen"
        MinHeight="300" MinWidth="400"
        Background="#0d1117"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#161b22" Padding="10,8" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTitle" Text="Juego en ejecución" Foreground="#e6edf3" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock x:Name="TxtFps" Text=" · FPS: --" Foreground="#58a6ff" FontSize="12" Margin="8,0,0,0"/>
                    <TextBlock x:Name="TxtScene" Text="" Foreground="#8b949e" FontSize="11" Margin="8,0,0,0"/>
                </StackPanel>
                <Button x:Name="BtnStop" Grid.Column="1" Content="■ Detener" Width="90" Height="28" Padding="8,0"
                        Background="#da3633" Foreground="White" BorderThickness="0" Click="BtnStop_OnClick"/>
            </Grid>
        </Border>
        <Border Grid.Row="1" x:Name="GameArea" Background="#0d1117" Margin="8">
            <Grid>
                <TextBlock x:Name="TxtPlaceholder" Text="Vista del juego (render en desarrollo)" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#6e7681" FontSize="13"/>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="#161b22" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,1,0,0">
            <TextBlock x:Name="TxtInfo" Text="Frame: 0 · Tiempo: 0 s" Foreground="#8b949e" FontSize="11"/>
        </Border>
    </Grid>
</Window>
