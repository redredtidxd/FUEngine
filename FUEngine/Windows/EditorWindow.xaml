<Window x:Class="FUEngine.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FUEngine"
        xmlns:spotlight="clr-namespace:FUEngine.Spotlight"
        Title="Editor - FUEngine" Height="620" Width="920"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#0d1117"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <!-- Barra mapa: botón de herramienta activo resaltado -->
        <Style TargetType="RadioButton" x:Key="MapToolRadioStyle">
            <Setter Property="Foreground" Value="#e6edf3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="Transparent" BorderBrush="#30363d" BorderThickness="1" Padding="5,3" MinWidth="28" MinHeight="26">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#21262d"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#388bfd"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#58a6ff"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Botón "+" de pestañas: siempre visible (verde, texto blanco), sin heredar estilo global -->
        <Style x:Key="TabAddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="0" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2ea043"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Barra de menú principal -->
        <Menu Grid.Row="0" Background="#161b22" Foreground="#e6edf3" BorderBrush="#30363d" BorderThickness="0,0,0,1"
              ItemContainerStyle="{StaticResource TopLevelMenuItemStyle}">
            <MenuItem Header="Archivo" Foreground="#e6edf3">
                <MenuItem Header="Nuevo proyecto..." Click="MenuNuevoProyecto_OnClick"/>
                <MenuItem Header="Abrir proyecto..." Click="MenuAbrirProyecto_OnClick"/>
                <Separator/>
                <MenuItem x:Name="MenuGuardarEscena" Header="Guardar escena" Click="MenuGuardarEscena_OnClick" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Guardar escena como…" Click="MenuGuardarEscenaComo_OnClick"/>
                <MenuItem x:Name="MenuGuardarTodo" Header="Guardar todo" Click="MenuGuardarTodo_OnClick" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="Importar asset…" Click="MenuImportarAsset_OnClick" ToolTip="Copia imágenes a Assets/Sprites y audio a Assets/Audio"/>
                <Separator/>
                <MenuItem Header="Exportar…" Click="MenuExportarParcial_OnClick"/>
                <Separator/>
                <MenuItem Header="Salir al Hub" Click="MenuSalirProyecto_OnClick" ToolTip="Cierra el proyecto y vuelve a la pantalla de inicio sin cerrar el programa"/>
                <MenuItem Header="Salir del motor" Click="MenuSalirMotor_OnClick" ToolTip="Cierra completamente la aplicación"/>
            </MenuItem>
            <MenuItem Header="Editar" Foreground="#e6edf3">
                <MenuItem x:Name="MenuDeshacer" Header="Deshacer" Click="MenuDeshacer_OnClick" InputGestureText="Ctrl+Z" IsEnabled="False"/>
                <MenuItem x:Name="MenuRehacer" Header="Rehacer" Click="MenuRehacer_OnClick" InputGestureText="Ctrl+Y · Ctrl+Mayús+Z" IsEnabled="False"/>
                <Separator/>
                <MenuItem Header="Cortar" IsEnabled="False" ToolTip="No disponible en el lienzo del mapa (usa Copiar)"/>
                <MenuItem x:Name="MenuCopiarZona" Header="Copiar" Click="MenuCopiarZona_OnClick" InputGestureText="Ctrl+C"/>
                <MenuItem x:Name="MenuPegarZona" Header="Pegar" Click="MenuPegarZona_OnClick" InputGestureText="Ctrl+V"/>
                <MenuItem x:Name="MenuDuplicarZona" Header="Duplicar zona (copiar y pegar al lado)" Click="MenuDuplicarZona_OnClick"/>
                <Separator/>
                <MenuItem x:Name="MenuSnapshot" Header="Crear snapshot del mapa" Click="MenuSnapshot_OnClick" ToolTip="Guardar estado actual para revertir después"/>
                <MenuItem x:Name="MenuRevertSnapshot" Header="Revertir a snapshot" Click="MenuRevertSnapshot_OnClick" ToolTip="Restaurar último snapshot"/>
                <Separator/>
                <MenuItem Header="Borrar" x:Name="MenuBorrarObjeto" Click="MenuBorrarObjeto_OnClick" InputGestureText="Del"/>
                <Separator/>
                <MenuItem Header="Preferencias del editor…" Click="MenuPreferenciasEditor_OnClick" ToolTip="Tema, idioma y rutas en %LocalAppData%\FUEngine"/>
                <MenuItem Header="Atajos de teclado…" Click="MenuAtajos_OnClick"/>
            </MenuItem>
            <MenuItem Header="Proyecto" Foreground="#e6edf3">
                <MenuItem Header="Ajustes del proyecto (.FUE)…" Click="MenuAjustesProyectoManifest_OnClick" ToolTip="Selecciona el manifiesto en el Explorador y muestra resolución, autor y royalty en el Inspector"/>
                <MenuItem Header="Editor avanzado del proyecto…" Click="MenuEditorProyectoAvanzado_OnClick" ToolTip="Chunks, rutas, escenas y opciones detalladas"/>
                <MenuItem Header="Configurar chunks (en editor avanzado)…" Click="MenuConfigurarChunks_OnClick"/>
                <MenuItem Header="Gestionar scripts" Click="MenuGestionarScripts_OnClick" ToolTip="Abre la pestaña Scripts"/>
                <Separator/>
                <MenuItem Header="Explorar biblioteca global…" Click="MenuAssetsLibrary_OnClick" ToolTip="Copia assets de la biblioteca global al proyecto"/>
                <Separator/>
                <MenuItem Header="Verificar integridad" Click="MenuVerificarIntegridad_OnClick"/>
                <MenuItem Header="Limpiar archivos huérfanos" Click="MenuLimpiarHuerfanos_OnClick" ToolTip="Elimina mapas y objetos que ya no pertenecen a ninguna escena del proyecto"/>
                <MenuItem Header="Limpiar caché del motor…" Click="MenuLimpiarCacheMotor_OnClick" ToolTip="Borra Vulkan y Cache en AppData si el editor o el runtime fallan"/>
                <Separator/>
                <MenuItem Header="Guardar snapshot" Click="MenuGuardarSnapshot_OnClick"/>
                <MenuItem Header="Cargar snapshot…" Click="MenuCargarSnapshot_OnClick"/>
                <Separator/>
                <MenuItem Header="Simular (vista previa)" Click="MenuSimular_OnClick"/>
                <Separator/>
                <MenuItem Header="Exportar build del juego…" Click="MenuExportBuild_OnClick" ToolTip="Genera ejecutable + carpeta Data para distribuir"/>
                <Separator/>
                <MenuItem x:Name="MenuIniciarJuego" Header="Iniciar juego (escena actual)" Click="MenuIniciarJuego_OnClick" ToolTip="Play con la escena cargada en el editor."/>
                <MenuItem x:Name="MenuIniciarJuegoMain" Header="Iniciar juego (escena principal)" Click="MenuIniciarJuegoMain_OnClick" ToolTip="Play cargando objetos desde disco (configuración del proyecto)."/>
                <MenuItem x:Name="MenuDetenerJuego" Header="Detener juego" Click="MenuDetenerJuego_OnClick" IsEnabled="False"/>
                <MenuItem x:Name="MenuPausarJuego" Header="Pausar" Click="MenuPausarJuego_OnClick" IsEnabled="False"/>
                <MenuItem x:Name="MenuReanudarJuego" Header="Reanudar" Click="MenuReanudarJuego_OnClick" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="Mapa" Foreground="#e6edf3">
                <MenuItem x:Name="MenuCrearScene" Header="Crear nueva escena" Click="MenuCrearScene_OnClick" ToolTip="Crear una nueva escena en el proyecto"/>
                <MenuItem x:Name="MenuAbrirScene" Header="Abrir escena…" SubmenuOpened="MenuAbrirScene_SubmenuOpened" ToolTip="Abrir una escena del proyecto en una nueva pestaña"/>
                <MenuItem x:Name="MenuDuplicarScene" Header="Duplicar escena actual" Click="MenuDuplicarScene_OnClick" ToolTip="Duplicar la escena actual"/>
                <MenuItem x:Name="MenuEliminarScene" Header="Eliminar escena actual" Click="MenuEliminarScene_OnClick" ToolTip="Eliminar la escena actual y sus archivos"/>
                <MenuItem x:Name="MenuImportarScene" Header="Importar escena de otro proyecto…" Click="MenuImportarScene_OnClick" ToolTip="Importar una escena desde otro proyecto"/>
                <Separator/>
                <MenuItem Header="Ajustes de escena (fondo del visor)…" Click="MenuMapaAjustesFondo_OnClick" ToolTip="Color de fondo del lienzo y vista del mapa"/>
                <MenuItem Header="Propiedades del mapa (tamaño/chunks)…" Click="MenuPropiedadesMapa_OnClick"/>
                <MenuItem Header="Tamaño de tiles…" Click="MenuTamañoTiles_OnClick"/>
                <Separator/>
                <MenuItem Header="Regenerar colisiones (editor)…" Click="MenuMapaRegenerarColisiones_OnClick" ToolTip="Abre el flujo del editor de colisiones para sprites/tiles"/>
            </MenuItem>
            <MenuItem Header="Semillas" Foreground="#e6edf3">
                <MenuItem Header="Crear nueva semilla…" Click="MenuCrearNuevaSemilla_OnClick"/>
                <MenuItem Header="Explorador de semillas globales…" Click="MenuExploradorSemillasGlobales_OnClick" ToolTip="Carpeta GlobalTemplates en AppData"/>
            </MenuItem>
            <MenuItem Header="Ventana" Foreground="#e6edf3">
                <MenuItem x:Name="MenuVerJerarquia" Header="Panel jerarquía / mapa" IsCheckable="True" IsChecked="True" Click="MenuVerPanel_OnClick"/>
                <MenuItem x:Name="MenuVerInspector" Header="Panel Inspector" IsCheckable="True" IsChecked="True" Click="MenuVerPanel_OnClick"/>
                <MenuItem x:Name="MenuVerConsola" Header="Pestaña Consola" IsCheckable="True" IsChecked="False" Click="MenuVerPanel_OnClick"/>
                <MenuItem x:Name="MenuVerJuego" Header="Pestaña Juego (Play embebido)" IsCheckable="True" IsChecked="False" Click="MenuVerPanel_OnClick"/>
                <Separator/>
                <MenuItem Header="Viewport (Mapa)" Tag="Mapa" Click="MenuVentanaTab_OnClick"/>
                <MenuItem Header="Explorador de archivos (pestaña)" Tag="Explorador" Click="MenuVentanaTab_OnClick"/>
                <MenuItem Header="Editor de scripts" Tag="Scripts" Click="MenuVentanaTab_OnClick"/>
                <MenuItem Header="Consola" Tag="Consola" Click="MenuVentanaTab_OnClick"/>
                <Separator/>
                <MenuItem Header="Centro del mapa (cámara)" Click="BtnGoToOrigin_OnClick" ToolTip="Marco azul en el centro geométrico del mapa finito; en infinitos cámara en (0,0) mundo."/>
                <MenuItem Header="Visor: esquina mundo (0,0)" Click="BtnVisorMundoZero_OnClick" ToolTip="Alinea el marco para que el área de juego tenga su esquina superior izquierda en la casilla (0,0)."/>
                <MenuItem x:Name="MenuAbrirEscena" Header="Abrir escena…" SubmenuOpened="MenuAbrirEscena_SubmenuOpened"/>
                <Separator/>
                <MenuItem Header="Restablecer disposición…" Click="MenuResetLayout_OnClick" ToolTip="Quita pestañas extra y restaura paneles por defecto"/>
            </MenuItem>
            <MenuItem Header="Herramientas" Foreground="#e6edf3">
                <MenuItem Header="Pincel" Click="MenuHerramienta_OnClick" Tag="Pintar"/>
                <MenuItem Header="Rectángulo relleno" Click="MenuHerramienta_OnClick" Tag="Rectangulo"/>
                <MenuItem Header="Relleno (Shift+clic)" Click="MenuHerramienta_OnClick" Tag="Relleno"/>
                <MenuItem Header="Goma" Click="MenuHerramienta_OnClick" Tag="Goma"/>
                <MenuItem Header="Sello (pegar zona)" Click="MenuHerramienta_OnClick" Tag="Stamp"/>
                <MenuItem Header="Seleccionar" Click="MenuHerramienta_OnClick" Tag="Seleccionar"/>
                <MenuItem Header="Colocar objeto" Click="MenuHerramienta_OnClick" Tag="Colocar"/>
                <MenuItem Header="Zona (copiar/pegar)" Click="MenuHerramienta_OnClick" Tag="Zona"/>
                    <MenuItem Header="Medir" Click="MenuHerramienta_OnClick" Tag="Medir"/>
                    <MenuItem Header="Pixel (edición píxel a píxel)" Click="MenuHerramienta_OnClick" Tag="PixelEdit"/>
            </MenuItem>
            <MenuItem Header="Ayuda" Foreground="#e6edf3">
                <MenuItem Header="Manual rápido" Click="MenuDocumentacion_OnClick" ToolTip="Primeros pasos con el proyecto abierto: mapa, escenas, Play"/>
                <MenuItem Header="Manual completo" Click="MenuDocumentacionCompleta_OnClick" ToolTip="Índice de todos los temas; empieza en «Cómo hacer un juego»"/>
                <MenuItem Header="API Lua — sintaxis y librería…" Click="MenuLuaReference_OnClick" ToolTip="Palabras clave Lua y guías de librería estándar"/>
                <Separator/>
                <MenuItem Header="Abrir carpeta de logs…" Click="MenuAbrirCarpetaLogs_OnClick" ToolTip="Sesiones y fallos en %LocalAppData%\FUEngine\logs"/>
                <MenuItem Header="Reportar un bug (GitHub)…" Click="MenuReportarBug_OnClick"/>
                <Separator/>
                <MenuItem Header="Acerca de FUEngine…" Click="MenuAcercaDe_OnClick"/>
            </MenuItem>
        </Menu>
        <!-- Barra de herramientas dinámica según tab activo -->
        <Grid Grid.Row="1" Background="#161b22">
            <!-- Toolbar Mapa: dibujo, selección, capas, zoom -->
            <Border x:Name="ToolbarMapa" Background="#161b22" Padding="6,4" BorderBrush="#30363d" BorderThickness="0,0,0,1" Visibility="Visible">
            <ToolBarTray Background="Transparent">
                <ToolBar Background="Transparent" Foreground="#e6edf3" OverflowMode="AsNeeded" ToolBarTray.IsLocked="True">
                    <ToolBar.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="#e6edf3"/>
                            <Setter Property="Background" Value="#21262d"/>
                            <Setter Property="BorderBrush" Value="#30363d"/>
                        </Style>
                    </ToolBar.Resources>
                    <Button x:Name="BtnStopPlay" Content="■ Detener" Width="80" Height="26" Margin="4,0,0,0" Padding="6,0" Background="#da3633" Foreground="White" BorderThickness="0"
                            ToolTip="Detener el juego" Click="BtnStopPlay_OnClick" Visibility="Collapsed"/>
                    <Button x:Name="BtnPausePlay" Content="⏸ Pausar" Width="70" Height="26" Margin="2,0,0,0" Padding="6,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"
                            ToolTip="Pausar el juego" Click="BtnPausePlay_OnClick" Visibility="Collapsed"/>
                    <Separator/>
                    <!-- Dibujo (solo iconos; nombre en ToolTip) -->
                    <RadioButton x:Name="ToolPintar" Style="{StaticResource MapToolRadioStyle}" GroupName="Tool" Checked="Tool_OnChecked" Margin="0,0,1,0"
                                 ToolTip="Pincel — pintar tiles (arrastrar). Mayús+clic: relleno por inundación en la capa activa.">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xEC88;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                    <RadioButton x:Name="ToolRectangulo" Style="{StaticResource MapToolRadioStyle}" GroupName="Tool" Checked="Tool_OnChecked" Margin="0,0,1,0"
                                 ToolTip="Rectángulo relleno — arrastra para rellenar un bloque con el tile elegido (plataformas, habitaciones).">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE739;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                    <RadioButton x:Name="ToolRelleno" Style="{StaticResource MapToolRadioStyle}" GroupName="Tool" Checked="Tool_OnChecked" Margin="0,0,1,0"
                                 ToolTip="Cubeta — relleno por inundación (también Mayús+clic con el pincel).">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE73F;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                    <RadioButton x:Name="ToolGoma" Style="{StaticResource MapToolRadioStyle}" GroupName="Tool" Checked="Tool_OnChecked" Margin="0,0,1,0"
                                 ToolTip="Goma — borrar tiles en la capa activa.">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE75C;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                    <RadioButton x:Name="ToolStamp" Style="{StaticResource MapToolRadioStyle}" GroupName="Tool" Checked="Tool_OnChecked" Margin="0,0,6,0"
                                 ToolTip="Sello — pegar la zona copiada (tras copiar con la herramienta Zona o menú Zona).">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE8C8;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                    <Separator/>
                    <!-- Selección y colocación -->
                    <RadioButton x:Name="ToolSeleccionar" Style="{StaticResource MapToolRadioStyle}" GroupName="Tool" IsChecked="True" Checked="Tool_OnChecked" Margin="0,0,1,0"
                                 ToolTip="Selección (marco) — objetos o rectángulo de tiles en el mapa; Supr borra la selección.">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE762;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                    <RadioButton x:Name="ToolColocar" Style="{StaticResource MapToolRadioStyle}" GroupName="Tool" Checked="Tool_OnChecked" Margin="0,0,1,0"
                                 ToolTip="Colocar objeto — usa la definición activa (Inspector / resumen del mapa).">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE81D;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                    <RadioButton x:Name="ToolZona" Style="{StaticResource MapToolRadioStyle}" GroupName="Tool" Checked="Tool_OnChecked" Margin="0,0,1,0"
                                 ToolTip="Zona — triggers, copiar y pegar región de tiles.">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE81E;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                    <RadioButton x:Name="ToolMedir" Style="{StaticResource MapToolRadioStyle}" GroupName="Tool" Checked="Tool_OnChecked" Margin="0,0,1,0"
                                 ToolTip="Medir — dos clics para distancia en casillas.">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xECC6;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                    <RadioButton x:Name="ToolPixelEdit" Style="{StaticResource MapToolRadioStyle}" GroupName="Tool" Checked="Tool_OnChecked" Margin="0,0,6,0"
                                 ToolTip="Píxeles — editar el arte del tile en la celda (editor por celda).">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xEA80;" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                    <Separator/>
                    <!-- Vista / máscaras / brocha -->
                    <Button x:Name="BtnVisual" Width="28" Height="26" Padding="0" ToolTip="Vista, máscaras y tamaño del pincel" Click="BtnVisual_OnClick" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE890;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#e6edf3"/>
                    </Button>
                    <Popup x:Name="PopupVisual" PlacementTarget="{Binding ElementName=BtnVisual}" Placement="Bottom" StaysOpen="False">
                        <Border Background="#161b22" BorderBrush="#30363d" BorderThickness="1" Padding="10,8">
                            <StackPanel MinWidth="200">
                                <TextBlock Text="Pincel (brocha)" FontWeight="SemiBold" Foreground="#e6edf3" FontSize="11" Margin="0,0,0,6"/>
                                <TextBlock Text="Tamaño" Foreground="#8b949e" FontSize="10" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbBrushSize" Width="100" SelectedIndex="0" SelectionChanged="CmbBrushSize_OnSelectionChanged"
                                          Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,0,0,8">
                                    <ComboBoxItem Content="1×1" Foreground="#e6edf3"/>
                                    <ComboBoxItem Content="2×2" Foreground="#e6edf3"/>
                                    <ComboBoxItem Content="3×3" Foreground="#e6edf3"/>
                                </ComboBox>
                                <TextBlock Text="Rotación (referencia)" Foreground="#8b949e" FontSize="10" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbBrushRotation" Width="100" SelectedIndex="0" SelectionChanged="CmbBrushRotation_OnSelectionChanged"
                                          Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,0,0,12">
                                    <ComboBoxItem Content="0°" Foreground="#e6edf3"/>
                                    <ComboBoxItem Content="90°" Foreground="#e6edf3"/>
                                    <ComboBoxItem Content="180°" Foreground="#e6edf3"/>
                                    <ComboBoxItem Content="270°" Foreground="#e6edf3"/>
                                </ComboBox>
                                <TextBlock Text="Visualización / máscaras" FontWeight="SemiBold" Foreground="#e6edf3" FontSize="11" Margin="0,0,0,8"/>
                                <CheckBox x:Name="ChkResaltarInteractivos" Content="Resaltar interactivos" IsChecked="True" Foreground="#e6edf3" Margin="0,2" ToolTip="Borde en tiles con script" Checked="ChkResaltar_OnChanged" Unchecked="ChkResaltar_OnChanged"/>
                                <CheckBox x:Name="ChkMaskColision" Content="Máscara colisión" Foreground="#e6edf3" Margin="0,2" ToolTip="Solo tiles con colisión" Checked="ChkMask_OnChanged" Unchecked="ChkMask_OnChanged"/>
                                <CheckBox x:Name="ChkMaskScripts" Content="Máscara scripts" Foreground="#e6edf3" Margin="0,2" ToolTip="Solo tiles con script" Checked="ChkMask_OnChanged" Unchecked="ChkMask_OnChanged"/>
                                <CheckBox x:Name="ChkSnap" Content="Snap a grid" IsChecked="True" Foreground="#e6edf3" Margin="0,2" ToolTip="Alinear al grid" Checked="ChkSnap_OnChanged" Unchecked="ChkSnap_OnChanged"/>
                                <CheckBox x:Name="ChkGridVisible" Content="Mostrar grid" IsChecked="True" Foreground="#e6edf3" Margin="0,2" ToolTip="Cuadrícula del mapa" Checked="ChkGridVisible_OnChanged" Unchecked="ChkGridVisible_OnChanged"/>
                                <CheckBox x:Name="ChkShowVisibleArea" Content="Mostrar área visible" IsChecked="True" Foreground="#e6edf3" Margin="0,2" ToolTip="Marco del área de juego (resolución lógica en px). Alt+clic y arrastrar mueve la cámara; se guarda en el proyecto." Checked="ChkShowVisibleArea_OnChanged" Unchecked="ChkShowVisibleArea_OnChanged"/>
                                <CheckBox x:Name="ChkKeepPlayWithMap" Content="Play activo también en pestaña Mapa" IsChecked="True" Foreground="#e6edf3" Margin="0,2" ToolTip="No pausa el sandbox del tab Juego al editar en Mapa (Mapa + Play a la vez). Se guarda en proyecto.json." Checked="ChkKeepPlayWithMap_OnChanged" Unchecked="ChkKeepPlayWithMap_OnChanged"/>
                                <CheckBox x:Name="ChkShowStreamingGizmos" Content="Radios streaming (chunks)" Foreground="#e6edf3" Margin="0,2" ToolTip="Rectángulos Chebyshev: verde = ChunkLoadRadius; naranja = +ChunkStreamEvictMargin (centro en protagonista o 0,0)" Checked="ChkShowStreamingGizmos_OnChanged" Unchecked="ChkShowStreamingGizmos_OnChanged"/>
                                <CheckBox x:Name="ChkShowColliders" Content="Mostrar colisiones" Foreground="#e6edf3" Margin="0,2" ToolTip="Overlay de formas de colisión (verde=sólido, naranja=trigger, azul=one-way)" Checked="ChkShowColliders_OnChanged" Unchecked="ChkShowColliders_OnChanged"/>
                                <CheckBox x:Name="ChkShowCoords" Content="Coordenadas en tiles" IsChecked="True" Foreground="#e6edf3" Margin="0,2" ToolTip="Mostrar x,y en cada tile" Checked="ChkShowCoords_OnChanged" Unchecked="ChkShowCoords_OnChanged"/>
                                <TextBlock Text="Color grid" Foreground="#8b949e" FontSize="10" Margin="0,6,0,2"/>
                                <ComboBox x:Name="CmbGridColor" Width="120" SelectedIndex="0" SelectionChanged="CmbGridColor_OnSelectionChanged"
                                          Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d">
                                    <ComboBoxItem Content="Gris" Foreground="#e6edf3" Tag="#30363d"/>
                                    <ComboBoxItem Content="Azul suave" Foreground="#e6edf3" Tag="#384a6a"/>
                                    <ComboBoxItem Content="Blanco suave" Foreground="#e6edf3" Tag="#6e7681"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Separator/>
                    <TextBlock x:Name="ToolbarMapTileHint" Text="Pincel: elige el tile en la pestaña «Tiles» (panel inferior)." VerticalAlignment="Center" Foreground="#8b949e" FontSize="10" Margin="0,0,8,0" MaxWidth="280" TextWrapping="Wrap"/>
                    <Separator/>
                    <!-- Zoom -->
                    <Button x:Name="BtnZoomOut" Width="26" Height="22" Padding="0" Click="BtnZoom_OnClick" Tag="-" ToolTip="Alejar (también Ctrl+rueda del ratón)" Background="#21262d" BorderBrush="#30363d">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE949;" Foreground="#e6edf3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <TextBlock x:Name="TxtZoom" Text="100%" VerticalAlignment="Center" Margin="6,0" MinWidth="36" Foreground="#8b949e" FontSize="10"/>
                    <Button x:Name="BtnZoomIn" Width="26" Height="22" Padding="0" Click="BtnZoom_OnClick" Tag="+" ToolTip="Acercar (también Ctrl+rueda del ratón)" Background="#21262d" BorderBrush="#30363d">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE948;" Foreground="#e6edf3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnGoToOrigin" Content="Centro mapa" MinWidth="88" Height="26" Margin="8,0,0,0" Padding="8,2" FontSize="11" FontWeight="SemiBold" ToolTip="Centro geométrico del mapa finito (marco azul) y scroll. Mapas infinitos: cámara en (0,0) mundo." Click="BtnGoToOrigin_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#388bfd"/>
                    <Button x:Name="BtnVisorMundoZero" Content="Mundo 0,0" MinWidth="88" Height="26" Margin="4,0,0,0" Padding="8,2" FontSize="11" FontWeight="SemiBold" ToolTip="Alinea el visor para que la esquina superior izquierda del área de juego (marco) coincida con la casilla mundo (0,0)." Click="BtnVisorMundoZero_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#388bfd"/>
                    <Separator/>
                    <!-- Selección activa: rotar/flip/rellenar -->
                    <TextBlock x:Name="LblSelection" Text="Sel:" VerticalAlignment="Center" Foreground="#8b949e" FontSize="10" Margin="0,0,4,0" Visibility="Collapsed"/>
                    <Button x:Name="BtnRotate90" Content="90°" Width="28" Height="22" Margin="1,0" ToolTip="Rotar 90°" Click="BtnTransformSelection_OnClick" Tag="Rotate90" Visibility="Collapsed"/>
                    <Button x:Name="BtnRotate180" Content="180°" Width="28" Height="22" Margin="1,0" ToolTip="Rotar 180°" Click="BtnTransformSelection_OnClick" Tag="Rotate180" Visibility="Collapsed"/>
                    <Button x:Name="BtnFlipH" Content="↔" Width="26" Height="22" Margin="1,0" ToolTip="Voltear H" Click="BtnTransformSelection_OnClick" Tag="FlipH" Visibility="Collapsed"/>
                    <Button x:Name="BtnFlipV" Content="↕" Width="26" Height="22" Margin="1,0" ToolTip="Voltear V" Click="BtnTransformSelection_OnClick" Tag="FlipV" Visibility="Collapsed"/>
                    <Button x:Name="BtnFillSelection" Content="Rellenar" Width="52" Height="22" Margin="1,0" ToolTip="Rellenar con tile actual" Click="BtnFillSelection_OnClick" Visibility="Collapsed"/>
                    <Button x:Name="BtnCopySelection" Content="C" Width="24" Height="22" Margin="1,0" ToolTip="Copiar (Ctrl+C)" Click="BtnCopySelection_OnClick" Visibility="Collapsed"/>
                    <Button x:Name="BtnPasteSelection" Content="V" Width="24" Height="22" Margin="1,0" ToolTip="Pegar (Ctrl+V)" Click="BtnPasteSelection_OnClick" Visibility="Collapsed"/>
                    <Button x:Name="BtnDuplicateZone" Content="Dup" Width="32" Height="22" Margin="1,0" ToolTip="Duplicar zona" Click="BtnDuplicateZone_OnClick" Visibility="Collapsed"/>
                    <Separator/>
                    <!-- Undo/Redo -->
                    <Button x:Name="BtnUndo" Width="26" Height="22" Padding="0" ToolTip="Deshacer (Ctrl+Z)" Click="MenuDeshacer_OnClick">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE10E;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#e6edf3"/>
                    </Button>
                    <Button x:Name="BtnRedo" Width="26" Height="22" Padding="0" ToolTip="Rehacer (Ctrl+Y o Ctrl+Mayús+Z)" Click="MenuRehacer_OnClick">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE10D;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#e6edf3"/>
                    </Button>
                </ToolBar>
            </ToolBarTray>
            </Border>
            <!-- Toolbar Scripts: run, debug, guardar -->
            <Border x:Name="ToolbarScripts" Background="#161b22" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Scripts" VerticalAlignment="Center" Foreground="#6e7681" FontSize="10" Margin="0,0,12,0"/>
                    <Button x:Name="ToolbarScriptRun" Content="Ejecutar" Width="80" Height="26" Padding="6,0" Background="#238636" Foreground="White" BorderThickness="0" ToolTip="Ejecutar script (F5)" Click="ToolbarScriptRun_OnClick"/>
                    <Button x:Name="ToolbarScriptDebug" Content="Depurar" Width="70" Height="26" Margin="8,0,0,0" Padding="6,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" ToolTip="Depurar script"/>
                    <Button x:Name="ToolbarScriptSave" Content="Guardar" Width="70" Height="26" Margin="4,0,0,0" Padding="6,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" ToolTip="Guardar (Ctrl+S)" Click="ToolbarScriptSave_OnClick"/>
                </StackPanel>
            </Border>
            <!-- Toolbar Tiles / Animaciones: edición y preview -->
            <Border x:Name="ToolbarTilesAnimaciones" Background="#161b22" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ToolbarTilesAnimacionesLabel" Text="Tiles" VerticalAlignment="Center" Foreground="#6e7681" FontSize="10" Margin="0,0,12,0"/>
                    <Button Content="Vista miniaturas" Width="120" Height="26" Padding="6,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" ToolTip="Vista del tileset"/>
                    <Button Content="Preview" Width="70" Height="26" Margin="8,0,0,0" Padding="6,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
                </StackPanel>
            </Border>
            <!-- Toolbar mínimo para Explorador / Consola -->
            <Border x:Name="ToolbarMinimal" Background="#161b22" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1" Visibility="Collapsed">
                <TextBlock x:Name="ToolbarMinimalLabel" Text="Explorador · Favoritos, recientes y árbol del proyecto" Foreground="#8b949e" FontSize="11" VerticalAlignment="Center"/>
            </Border>
        </Grid>
        <!-- Área: Jerarquía (izq) | Tabs + Mapa | Inspector (der) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="260" MinWidth="200"/>
            </Grid.ColumnDefinitions>
            <!-- Panel izquierdo: Tabs de Scene arriba, luego Jerarquía, Explorador abajo -->
            <Border x:Name="PanelJerarquia" Grid.Column="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,1,0" Padding="0">
                <Grid x:Name="GridLeftColumnRoot">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition x:Name="RowPlayHierarchy" Height="Auto" MaxHeight="140"/>
                        <RowDefinition x:Name="RowHierarchy" Height="*" MinHeight="80"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition x:Name="RowExplorer" Height="2*" MinHeight="120"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="ScenesBar" Grid.Row="0" Background="#161b22" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Escenas:" Foreground="#8b949e" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ItemsControl x:Name="ScenesStrip">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                <Button x:Name="BtnPlay" ToolTip="Play con la escena actual del editor." Click="BtnPlay_OnClick"
                                        Width="160" Height="32" Padding="10,4" FontSize="12" FontWeight="SemiBold"
                                        Background="#238636" Foreground="White" BorderThickness="0" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="▶" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Play escena actual" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnPlayMainScene" ToolTip="Play cargando la escena principal desde disco." Click="BtnPlayMainScene_OnClick"
                                        Width="180" Height="32" Margin="8,0,0,0" Padding="10,4" FontSize="12" FontWeight="SemiBold"
                                        Background="#1f6feb" Foreground="White" BorderThickness="0" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏯" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Play escena principal" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <local:PlayHierarchyPanel x:Name="PlayHierarchyPanel" Grid.Row="1" Visibility="Collapsed"/>
                    <local:MapHierarchyPanel x:Name="MapHierarchy" Grid.Row="2"/>
                    <GridSplitter x:Name="SplitterJerarquiaExplorer" Grid.Row="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#30363d" ResizeDirection="Rows" ShowsPreview="False"/>
                    <local:ProjectExplorerPanel x:Name="ProjectExplorer" Grid.Row="4"/>
                    <TabControl x:Name="LeftBottomTabs" Grid.Row="4" Visibility="Collapsed" Background="#161b22" BorderThickness="0" Padding="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Foreground" Value="#e6edf3"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Bd" Background="#21262d" BorderBrush="#30363d" BorderThickness="1" CornerRadius="4,4,0,0" Padding="{TemplateBinding Padding}" Margin="0,0,4,0">
                                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  TextElement.Foreground="#e6edf3"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#30363d"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#58a6ff"/>
                                                    <Setter Property="TextElement.Foreground" Value="#f0f6fc"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2d333b"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>
                        <TabItem Header="Explorador">
                            <Border x:Name="BorderLeftExplorerHost" Background="#161b22"/>
                        </TabItem>
                        <TabItem Header="Tiles">
                            <Grid Background="#161b22">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="6,6,6,4">
                                    <TextBlock Text="Tileset (catálogo)" Foreground="#8b949e" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="CmbTilesetCatalog" MinHeight="26"
                                              Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"
                                              SelectionChanged="CmbTilesetCatalog_OnSelectionChanged"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkFreeAtlasBrush" Grid.Row="1" Margin="8,0,8,0" Content="Recorte libre (atlas por píxeles)" Foreground="#e6edf3" FontSize="11"
                                          ToolTip="Si está activo, arrastra en la vista del atlas para elegir un rectángulo fuente (subrect). También puedes usar Alt+arrastre en la rejilla."
                                          Checked="ChkFreeAtlasBrush_OnChanged" Unchecked="ChkFreeAtlasBrush_OnChanged"/>
                                <Border x:Name="BorderAtlasFreePick" Grid.Row="2" Margin="6,4,6,4" Height="140" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" CornerRadius="4" Visibility="Collapsed"
                                        ToolTip="Arrastra para definir el recorte en píxeles de la textura.">
                                    <Grid x:Name="GridAtlasFreePickHost" ClipToBounds="True"
                                          MouseLeftButtonDown="GridAtlasFreePickHost_OnMouseLeftButtonDown" MouseMove="GridAtlasFreePickHost_OnMouseMove" MouseLeftButtonUp="GridAtlasFreePickHost_OnMouseLeftButtonUp" MouseLeave="GridAtlasFreePickHost_OnMouseLeave">
                                        <Image x:Name="ImgAtlasFull" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                        <Rectangle x:Name="RectAtlasSelectionOverlay" Stroke="#58a6ff" StrokeThickness="1" Fill="#203880ff" Visibility="Collapsed" IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="3" MinHeight="80">
                                    <ScrollViewer x:Name="ScrollMapTilePicker" Margin="0,2,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="#161b22">
                                        <ItemsControl x:Name="CatalogTilePickerItems">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" Margin="4"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <TextBlock x:Name="TxtMapTilePickerEmpty" Margin="8" TextWrapping="Wrap" Foreground="#8b949e" FontSize="11" VerticalAlignment="Top" Visibility="Collapsed" IsHitTestVisible="False"/>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
            <GridSplitter x:Name="SplitterJerarquia" Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#30363d"/>
            <!-- Centro: Tabs (Mapa, Consola, etc.) -->
            <Grid Grid.Column="2">
                <TabControl x:Name="MainTabs" Background="#0d1117" BorderThickness="0"
                        AllowDrop="True" PreviewDragOver="MainTabs_PreviewDragOver"
                        SelectionChanged="MainTabs_OnSelectionChanged">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#21262d" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="0,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TabPanel x:Name="HeaderPanel" Grid.Column="0" IsItemsHost="True" Margin="2,4,2,4"/>
                                    <Button x:Name="BtnAddTab" Grid.Column="1" Style="{StaticResource TabAddButtonStyle}"
                                            Content="+" Width="36" Height="28" Margin="4,4,8,4" FontSize="18" FontWeight="Bold"
                                            Click="BtnAddTab_OnClick" ToolTip="Nueva pestaña (contextual según área activa)"
                                            Cursor="Hand"/>
                                </Grid>
                            </Border>
                            <Border Grid.Row="1" Background="#0d1117" BorderThickness="0" Padding="0">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                <TabItem x:Name="TabMapa" Header="Mapa" Tag="Mapa">
                    <Border Background="#0d1117" x:Name="MapViewport">
                        <Grid>
                            <ScrollViewer x:Name="ScrollViewer" FlowDirection="LeftToRight" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" CanContentScroll="False"
                                          Background="#161b22"
                                          ScrollChanged="ScrollViewer_OnScrollChanged"
                                          PreviewMouseWheel="ScrollViewer_OnPreviewMouseWheel"
                                          PreviewMouseDown="ScrollViewer_OnPreviewMouseDown"
                                          PreviewMouseMove="ScrollViewer_OnPreviewMouseMove"
                                          PreviewMouseUp="ScrollViewer_OnPreviewMouseUp">
                                <Canvas x:Name="MapCanvas" Width="800" Height="600" Background="#21262d"
                                    AllowDrop="True"
                                    MouseLeftButtonDown="MapCanvas_OnMouseLeftButtonDown"
                                    MouseDown="MapCanvas_OnMouseDown"
                                    MouseRightButtonDown="MapCanvas_OnMouseRightButtonDown"
                                    MouseMove="MapCanvas_OnMouseMove"
                                    MouseLeftButtonUp="MapCanvas_OnMouseLeftButtonUp"
                                    LostMouseCapture="MapCanvas_OnLostMouseCapture"
                                    MouseUp="MapCanvas_OnMouseUp"
                                    DragOver="MapCanvas_OnDragOver"
                                    Drop="MapCanvas_OnDrop"
                                    KeyDown="EditorWindow_OnKeyDown"
                                    Focusable="True"/>
                            </ScrollViewer>
                            <Border x:Name="CanvasWelcomeOverlay" Background="#1a2332" Cursor="Hand" MouseLeftButtonDown="CanvasWelcomeOverlay_OnMouseDown">
                                <Grid>
                                    <Rectangle Fill="{StaticResource PixelGridBrush}" Opacity="0.4"/>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                                        <TextBlock Text="Bienvenido a FUEngine" FontSize="20" FontWeight="SemiBold" Foreground="#e6edf3" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="Clic aquí o en el mapa para empezar. Herramienta Seleccionar por defecto." Foreground="#8b949e" FontSize="13" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="Pincel · Rect · Línea · Relleno · Goma · Cuentagotas · Stamp · Seleccionar · Del=Borrar  Ctrl+Z/Y" Foreground="#6e7681" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                        <TextBlock Text="↓ Clic para acceder al mapa" Foreground="#58a6ff" FontSize="12" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </TabItem>
                <TabItem x:Name="TabJuego" Header="Juego" Tag="Juego">
                    <local:GameTabContent x:Name="EmbeddedGameTabContent"/>
                </TabItem>
                <TabItem x:Name="TabConsola" Header="Consola" Tag="Consola">
                    <local:ConsoleTabContent/>
                </TabItem>
            </TabControl>
            </Grid>
            <GridSplitter x:Name="SplitterInspector" Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Background="#30363d"/>
            <Border x:Name="PanelInspector" Grid.Column="4" Background="#161b22" Padding="0" BorderBrush="#30363d" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition x:Name="RowLayersPanel" Height="200" MinHeight="100"/>
                        <RowDefinition x:Name="RowLayersSplitter" Height="4"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="BorderLayersPanelSectionTitle" Grid.Row="0" Background="#21262d" Padding="10,8" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                        <TextBlock Text="Capas" FontWeight="SemiBold" FontSize="13" Foreground="#e6edf3"/>
                    </Border>
                    <local:LayersPanel x:Name="LayersPanel" Grid.Row="1"/>
                    <GridSplitter x:Name="SplitterLayersInspector" Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#30363d" ResizeDirection="Rows" ShowsPreview="False"/>
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#21262d" Padding="10,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                            <TextBlock Text="Inspector" FontWeight="SemiBold" FontSize="12" Foreground="#e6edf3"/>
                        </Border>
                        <ContentControl Grid.Row="1" x:Name="InspectorPanel" Margin="8,8,8,8"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <Border Grid.Row="3" Background="#161b22" Padding="8,4" BorderBrush="#30363d" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtStatusBar" Text="X: 0  Y: 0  Chunk: (0,0)  |  Seleccionar" Foreground="#8b949e" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Atajos: 1-6 herramientas · Ctrl+Z/Y · Del · Rueda=zoom · Clic medio en mapa=muestrear tile · Clic central=pan marco · WASD=desplazar" Foreground="#6e7681" FontSize="10" VerticalAlignment="Center" Margin="16,0,0,0"/>
                </Grid>
                <Border Grid.Row="1" x:Name="LogBar" Background="#0d1117" Padding="6,3" Margin="0,4,0,0" BorderBrush="#30363d" BorderThickness="0,1,0,0" Visibility="Collapsed"
                        MouseLeftButtonDown="LogBar_MouseLeftButtonDown" Cursor="Hand">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Log:" Foreground="#6e7681" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtLastLog" Grid.Column="1" Text="" Foreground="#8b949e" FontSize="10" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="Clic para abrir Consola completa"/>
                        <TextBlock x:Name="TxtLogCounts" Grid.Column="2" Foreground="#8b949e" FontSize="10" VerticalAlignment="Center" Margin="8,0,8,0" ToolTip="Warnings y errores en el log"/>
                        <Button x:Name="BtnOpenConsola" Grid.Column="3" Content="Consola" Padding="6,2" FontSize="10" Click="BtnOpenConsola_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#30363d" ToolTip="Abrir pestaña Consola"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <!-- Toast: Info 3s, Warning 5s, Error fijo hasta clic -->
        <Border x:Name="ToastPanel" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,24"
               Background="#21262d" BorderBrush="#30363d" BorderThickness="1" CornerRadius="4" Padding="14,10"
               Visibility="Collapsed" MouseLeftButtonDown="ToastPanel_MouseLeftButtonDown" Cursor="Hand"
               ToolTip="Clic para cerrar (errores no se cierran solos)">
            <TextBlock x:Name="ToastText" Text="" Foreground="#e6edf3" FontSize="12" TextWrapping="Wrap" MaxWidth="320"/>
        </Border>
        </Grid>
        <Grid x:Name="SpotlightOverlay" Visibility="Collapsed" Panel.ZIndex="1000"
              Background="#B3000000" MouseLeftButtonDown="SpotlightBackdrop_OnMouseLeftButtonDown">
            <Border MaxWidth="760" MaxHeight="500" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" CornerRadius="8">
                <spotlight:SpotlightControl x:Name="SpotlightEmbedded" RequestClose="SpotlightEmbedded_RequestClose"/>
            </Border>
        </Grid>
        <Grid x:Name="DocumentationOverlay" Visibility="Collapsed" Panel.ZIndex="1001"
              Background="#B3000000" MouseLeftButtonDown="DocumentationBackdrop_OnMouseLeftButtonDown">
            <Border Margin="24,20,24,20" MinHeight="400" MinWidth="640"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                    MaxWidth="2000" MaxHeight="2000"
                    Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" CornerRadius="8"
                    MouseLeftButtonDown="DocumentationInner_OnMouseLeftButtonDown">
                <local:DocumentationHostControl x:Name="DocumentationEmbedded" RequestClose="DocumentationEmbedded_RequestClose"/>
            </Border>
        </Grid>
        <Grid x:Name="NewProjectWizardOverlay" Visibility="Collapsed" Panel.ZIndex="1002"
              Background="#CC0d1117" MouseLeftButtonDown="NewProjectWizardBackdrop_OnMouseLeftButtonDown">
            <Border MaxWidth="580" MaxHeight="640" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#161b22" BorderBrush="#30363d" BorderThickness="1" CornerRadius="8"
                    Padding="0" MouseLeftButtonDown="NewProjectWizardInner_OnMouseLeftButtonDown">
                <ContentControl x:Name="NewProjectWizardHost"/>
            </Border>
        </Grid>
        <!-- Definición de objeto para «Colocar objeto» (sin duplicar la UI en la barra) -->
