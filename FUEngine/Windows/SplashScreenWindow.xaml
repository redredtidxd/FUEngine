<Window x:Class="FUEngine.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="420" Height="220"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">
    <Border Background="#0d1117" CornerRadius="12" BorderBrush="#30363d" BorderThickness="1"
            Padding="32">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" x:Name="LogoContainer">
                <Image x:Name="LogoImage" Stretch="Uniform" Visibility="Collapsed"/>
                <StackPanel x:Name="PlaceholderLogo" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="FUEngine" FontSize="32" FontWeight="Bold" Foreground="#e6edf3"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Created by FUEngine" FontSize="12" Foreground="#8b949e"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
            <TextBlock Grid.Row="1" Text="Cargando..." Foreground="#6e7681" FontSize="11"
                       HorizontalAlignment="Center" Margin="0,16,0,0"/>
        </Grid>
    </Border>
</Window>
