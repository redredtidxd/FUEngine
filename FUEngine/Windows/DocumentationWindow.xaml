<Window x:Class="FUEngine.DocumentationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Documentación FUEngine" Height="720" Width="920" MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#0d1117">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Documentación de FUEngine" FontSize="18" FontWeight="SemiBold" Foreground="#e6edf3" Margin="0,0,0,10"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Text="Buscar en el índice" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtFilter" DockPanel.Dock="Top" Padding="8,6" Margin="0,0,0,8"
                         Background="#161b22" Foreground="#e6edf3" BorderBrush="#30363d"
                         TextChanged="TxtFilter_OnTextChanged"
                         ToolTip="Filtra temas por título o contenido"/>
                <ListBox x:Name="TopicList"
                         Background="#161b22" Foreground="#e6edf3" BorderBrush="#30363d"
                         SelectionChanged="TopicList_OnSelectionChanged"
                         DisplayMemberPath="Title"/>
            </DockPanel>
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>
            <Border Grid.Column="2" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" Padding="12,8" CornerRadius="4">
                <ScrollViewer x:Name="DetailScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="DetailPanel"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
