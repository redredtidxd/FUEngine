<UserControl x:Class="FUEngine.MapPropertiesInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Propiedades del mapa" FontWeight="SemiBold" FontSize="13" Foreground="#e6edf3" Margin="0,0,0,10"/>
            <Border Background="#21262d" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Tamaño de tiles (px)" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtTileSize" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,8"/>
                    <TextBlock Text="Ancho / Alto del mapa" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtMapSize" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,8"/>
                    <TextBlock Text="Chunk size" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtChunkSize" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,8"/>
                    <TextBlock Text="Capas" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtLayers" Foreground="#e6edf3" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Button x:Name="BtnOpenProjectConfig" Content="Abrir configuración del proyecto..." Padding="8,6" Click="BtnOpenProjectConfig_OnClick"
                            Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
