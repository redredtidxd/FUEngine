<UserControl x:Class="FUEngine.LayersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine"
             Background="#161b22">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#21262d" Padding="10,8" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <TextBlock Text="Capas" FontWeight="SemiBold" FontSize="13" Foreground="#e6edf3"/>
        </Border>
        <ListBox x:Name="LayersList" Grid.Row="1" Margin="4,4,4,4" Background="Transparent" Foreground="#e6edf3"
                 BorderThickness="0" SelectionMode="Single"
                 SelectionChanged="LayersList_OnSelectionChanged"
                 MouseDoubleClick="LayersList_OnMouseDoubleClick"
                 ContextMenuOpening="LayersList_OnContextMenuOpening">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="Foreground" Value="#e6edf3"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="6,6"/>
                    <Setter Property="MinHeight" Value="32"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#388bfd"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type local:LayerListItem}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnVisible" Width="24" Height="24" Margin="0,0,4,0" Padding="0" ToolTip="Mostrar/Ocultar"
                                Click="BtnVisible_OnClick" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Content="{Binding VisibilityIcon}" FontSize="12"/>
                        <Button x:Name="BtnLock" Width="24" Height="24" Margin="0,0,4,0" Padding="0" ToolTip="Bloquear/Desbloquear"
                                Click="BtnLock_OnClick" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Content="{Binding LockIcon}" FontSize="12"/>
                        <TextBlock x:Name="TxtName" Text="{Binding DisplayName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="180" Margin="4,0,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Border Grid.Row="2" Background="#21262d" Padding="6,6" BorderBrush="#30363d" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnAdd" Content="+ Capa de tiles" Width="120" Height="26" Margin="2,0" ToolTip="Añadir capa de tiles (Suelo, Paredes, etc.)" Click="BtnAdd_OnClick"
                        Background="#238636" Foreground="White" BorderThickness="0" FontWeight="SemiBold" FontSize="11"/>
                <Button x:Name="BtnRemove" Content="−" Width="28" Height="26" Margin="2,0" ToolTip="Eliminar capa" Click="BtnRemove_OnClick"
                        Background="#da3633" Foreground="White" BorderThickness="0" FontWeight="Bold" FontSize="14"/>
                <Button x:Name="BtnMoveUp" Content="▲" Width="28" Height="26" Margin="2,0" ToolTip="Subir capa" Click="BtnMoveUp_OnClick"
                        Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
                <Button x:Name="BtnMoveDown" Content="▼" Width="28" Height="26" Margin="2,0" ToolTip="Bajar capa" Click="BtnMoveDown_OnClick"
                        Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
