<UserControl x:Class="FUEngine.ProjectExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine"
             Background="#161b22">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:PathToFileNameConverter x:Key="PathToFileName"/>
        <local:StringToBrushConverter x:Key="StringToBrush"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <DataTemplate x:Key="QuickPathItemTemplate">
            <TextBlock Text="{Binding Converter={StaticResource PathToFileName}}" Foreground="#e6edf3" TextTrimming="CharacterEllipsis"/>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#21262d" Padding="10,8" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <TextBlock Text="Explorador" FontWeight="SemiBold" FontSize="13" Foreground="#e6edf3"/>
        </Border>
        <Border x:Name="CompactSectionsPanel" Grid.Row="1" Visibility="Collapsed" Background="Transparent" Padding="4,2" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <StackPanel>
                <Expander x:Name="ExpanderFavorites" Header="Favoritos" IsExpanded="True" Foreground="#e6edf3" Background="Transparent">
                    <ListBox x:Name="LstFavorites" MaxHeight="80" Background="#21262d" Foreground="#e6edf3" BorderThickness="0"
                             MouseDoubleClick="LstFavorites_OnMouseDoubleClick" SelectionChanged="LstQuick_OnSelectionChanged"
                             ItemTemplate="{StaticResource QuickPathItemTemplate}"/>
                </Expander>
                <Expander x:Name="ExpanderRecent" Header="Recientes" IsExpanded="True" Foreground="#e6edf3" Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="Por uso" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                            <ListBox x:Name="LstRecent" MaxHeight="80" Background="#21262d" Foreground="#e6edf3" BorderThickness="0"
                                     MouseDoubleClick="LstRecent_OnMouseDoubleClick" SelectionChanged="LstQuick_OnSelectionChanged"
                                     ItemTemplate="{StaticResource QuickPathItemTemplate}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock Text="Por creación" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                            <ListBox x:Name="LstRecentByCreation" MaxHeight="80" Background="#21262d" Foreground="#e6edf3" BorderThickness="0"
                                     MouseDoubleClick="LstRecentByCreation_OnMouseDoubleClick" SelectionChanged="LstQuick_OnSelectionChanged"
                                     ItemTemplate="{StaticResource QuickPathItemTemplate}"/>
                        </StackPanel>
                    </Grid>
                </Expander>
            </StackPanel>
        </Border>
        <TextBox x:Name="TxtSearch" Grid.Row="2" Margin="8,6,8,4" Padding="8,6" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"
                 ToolTip="Buscar por nombre o tipo." TextChanged="TxtSearch_OnTextChanged"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="8,0,8,6">
            <ComboBox x:Name="CmbFilter" Padding="6,4" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"
                      SelectionChanged="CmbFilter_OnSelectionChanged"
                      ToolTip="Filtros: Todos, Mapa/Tiles, Objetos, Scripts, Animaciones."/>
            <ComboBox x:Name="CmbSceneFilter" Margin="8,0,0,0" Padding="6,4" Width="120" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"
                      SelectionChanged="CmbSceneFilter_OnSelectionChanged" ToolTip="Filtro por uso en la escena actual."
                      Visibility="Collapsed"/>
        </StackPanel>
        <Grid Grid.Row="4" Margin="4,0,4,8">
            <TreeView x:Name="ProjectTree" Background="Transparent" Foreground="#e6edf3"
                      AllowDrop="True"
                      SelectedItemChanged="ProjectTree_OnSelectedItemChanged"
                      MouseDoubleClick="ProjectTree_OnMouseDoubleClick"
                      PreviewMouseRightButtonDown="ProjectTree_OnPreviewMouseRightButtonDown"
                      MouseRightButtonUp="ProjectTree_OnMouseRightButtonUp"
                      PreviewMouseLeftButtonDown="ProjectTree_OnPreviewMouseLeftButtonDown"
                      PreviewMouseMove="ProjectTree_OnPreviewMouseMove"
                      ContextMenuOpening="ProjectTree_OnContextMenuOpening"
                      DragOver="ProjectTree_OnDragOver"
                      Drop="ProjectTree_OnDrop">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                    <Setter Property="Foreground" Value="#e6edf3"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="MinHeight" Value="28"/>
                    <EventSetter Event="Expanded" Handler="ProjectTree_OnExpanded"/>
                    <EventSetter Event="Collapsed" Handler="ProjectTree_OnCollapsed"/>
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type local:ProjectExplorerItem}" ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{Binding FullPath}">
                        <TextBlock Text="{Binding Icon}" Width="18" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Border Width="6" Height="10" Margin="0,0,4,0" CornerRadius="1" VerticalAlignment="Center"
                                Background="{Binding Color, Converter={StaticResource StringToBrush}}"
                                Visibility="{Binding Color, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                        <TextBlock Text=" ●" Foreground="#58a6ff" Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}" Margin="2,0,0,0"/>
                        <TextBlock Text=" ⚠" Foreground="#f85149" Visibility="{Binding IsMissing, Converter={StaticResource BoolToVis}}" Margin="2,0,0,0"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            </TreeView>
            <ListBox x:Name="ProjectList" Visibility="Collapsed" Background="Transparent" Foreground="#e6edf3" BorderThickness="0"
                     SelectionChanged="ProjectList_OnSelectionChanged" MouseDoubleClick="ProjectList_OnMouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:ProjectExplorerItem}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Icon}" Width="18" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <ScrollViewer x:Name="ProjectGridScroll" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ProjectGrid" Background="Transparent">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:ProjectExplorerItem}">
                            <Border Width="72" Height="72" Margin="4" Background="#21262d" CornerRadius="4" Padding="4" Cursor="Hand"
                                    MouseLeftButtonDown="ProjectGridItem_OnMouseDown">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}" FontSize="24" HorizontalAlignment="Center" Foreground="#e6edf3"/>
                                    <TextBlock Text="{Binding Name}" Foreground="#e6edf3" FontSize="10" TextAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="64" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        <Border Grid.Row="5" x:Name="PreviewPanel" MinHeight="90" MaxHeight="160" Background="#21262d" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="TxtPreviewTitle" Text="Vista previa" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4" Grid.Row="0"/>
                <Border Grid.Row="1" x:Name="PreviewContent" Background="#0d1117" CornerRadius="4">
                    <Grid>
                        <TextBlock x:Name="TxtPreviewPlaceholder" Text="Seleccione un archivo" Foreground="#6e7681" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image x:Name="ImgPreview" Stretch="Uniform" MaxWidth="96" MaxHeight="96" Visibility="Collapsed"/>
                        <StackPanel x:Name="PreviewSoundPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Button x:Name="BtnPreviewPlay" Content="▶ Reproducir" Padding="8,4" Click="BtnPreviewPlay_OnClick" Background="#238636" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                        <ScrollViewer x:Name="PreviewScriptScroll" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" MaxHeight="80">
                            <TextBlock x:Name="TxtPreviewScript" Foreground="#8b949e" FontSize="10" TextWrapping="Wrap" Margin="4"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
