<UserControl x:Class="FUEngine.LogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine"
             Background="#161b22">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#21262d" Padding="6,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="Consola global" Foreground="#e6edf3" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button x:Name="BtnClear" Content="Limpiar" Margin="12,0,0,0" Padding="8,2" Click="BtnClear_OnClick"
                            Background="#30363d" Foreground="#e6edf3" BorderBrush="#484f58"/>
                    <TextBlock Text="Nivel:" Foreground="#6e7681" FontSize="11" VerticalAlignment="Center" Margin="14,0,4,0"/>
                    <CheckBox x:Name="ChkFilterInfo" Content="ℹ Info" Foreground="#e6edf3" IsChecked="True" VerticalAlignment="Center" Margin="2,0" Checked="Filter_OnChanged" Unchecked="Filter_OnChanged"/>
                    <CheckBox x:Name="ChkFilterWarning" Content="⚠ Aviso" Foreground="#e6edf3" IsChecked="True" VerticalAlignment="Center" Margin="2,0" Checked="Filter_OnChanged" Unchecked="Filter_OnChanged"/>
                    <CheckBox x:Name="ChkFilterError" Content="✕ Error" Foreground="#e6edf3" IsChecked="True" VerticalAlignment="Center" Margin="2,0" Checked="Filter_OnChanged" Unchecked="Filter_OnChanged"/>
                    <TextBlock Text="Origen:" Foreground="#6e7681" FontSize="11" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ComboBox x:Name="CmbFilterSource" Width="100" VerticalAlignment="Center" SelectionChanged="Filter_OnChanged"
                              Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" FontSize="11">
                        <ComboBoxItem Content="Todos" Tag="" IsSelected="True"/>
                        <ComboBoxItem Content="Lua" Tag="Lua"/>
                        <ComboBoxItem Content="Play" Tag="Play"/>
                        <ComboBoxItem Content="UI" Tag="UI"/>
                        <ComboBoxItem Content="Editor" Tag="Editor"/>
                    </ComboBox>
                </StackPanel>
                <DockPanel Grid.Row="1" Margin="0,8,0,0" LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left" Text="Buscar:" Foreground="#6e7681" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="TxtSearch" MinHeight="22" Padding="4,2"
                             Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" CaretBrush="#e6edf3"
                             TextChanged="TxtSearch_OnTextChanged"
                             ToolTip="Filtra por texto en mensaje u origen"/>
                </DockPanel>
            </Grid>
        </Border>
        <TextBlock Grid.Row="1" Text="Doble clic: abre script en la línea (si el error incluye archivo y línea)." Foreground="#6e7681" FontSize="10" Margin="6,4,6,2" TextWrapping="Wrap"/>
        <ListView Grid.Row="2" x:Name="LogList" Background="Transparent" Foreground="#e6edf3" BorderThickness="0"
                  MouseDoubleClick="LogList_OnMouseDoubleClick"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="2,2"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#21262d"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1f3a5f"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type local:LogEntry}">
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="Auto" MinWidth="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="IconBlock" Grid.Column="0" Text="ℹ" FontSize="14" VerticalAlignment="Top" HorizontalAlignment="Center" ToolTip="Info"/>
                        <TextBlock Grid.Column="1" Text="{Binding Time, StringFormat={}{0:HH:mm:ss}}" Foreground="#6e7681" FontSize="11" VerticalAlignment="Top"/>
                        <TextBlock x:Name="SourceBlock" Grid.Column="2" Text="{Binding Source, TargetNullValue='', FallbackValue=''}" FontSize="11" Foreground="#8b949e" Margin="0,0,8,0" VerticalAlignment="Top"/>
                        <TextBlock Grid.Column="3" Text="{Binding Message}" TextWrapping="Wrap" FontSize="12" VerticalAlignment="Top"/>
                    </Grid>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                            <Setter TargetName="IconBlock" Property="Text" Value="⚠"/>
                            <Setter TargetName="IconBlock" Property="ToolTip" Value="Advertencia"/>
                            <Setter TargetName="IconBlock" Property="Foreground" Value="#d29922"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Error">
                            <Setter TargetName="IconBlock" Property="Text" Value="✕"/>
                            <Setter TargetName="IconBlock" Property="ToolTip" Value="Error"/>
                            <Setter TargetName="IconBlock" Property="Foreground" Value="#f85149"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Level}" Value="Info">
                            <Setter TargetName="IconBlock" Property="Foreground" Value="#58a6ff"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Source}" Value="Lua">
                            <Setter TargetName="SourceBlock" Property="Foreground" Value="#79c0ff"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Source}" Value="Play">
                            <Setter TargetName="SourceBlock" Property="Foreground" Value="#a371f7"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Source}" Value="UI">
                            <Setter TargetName="SourceBlock" Property="Foreground" Value="#ffa657"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
