<UserControl x:Class="FUEngine.AnimationInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Propiedades de la animación" FontWeight="SemiBold" FontSize="13" Foreground="#e6edf3" Margin="0,0,0,10"/>
            <Border Background="#21262d" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Nombre" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtAnimName" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,8"/>
                    <TextBlock Text="FPS" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtFps" Foreground="#e6edf3" FontSize="11" Margin="0,0,0,8"/>
                    <TextBlock Text="Frames" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtFrames" Foreground="#e6edf3" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
