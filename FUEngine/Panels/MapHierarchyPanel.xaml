<UserControl x:Class="FUEngine.MapHierarchyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine"
             Background="#161b22">
    <UserControl.Resources>
        <local:LayerIndexToVisibilityConverter x:Key="LayerIndexToVisibility"/>
        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="Foreground" Value="#e6edf3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#21262d" Padding="10,8" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <TextBlock Text="Jerarquía de la escena" FontWeight="SemiBold" FontSize="13" Foreground="#e6edf3"/>
        </Border>
        <TreeView x:Name="HierarchyTree" Grid.Row="1" Margin="4,4,4,8" Background="Transparent" Foreground="#e6edf3"
                  AllowDrop="True"
                  SelectedItemChanged="HierarchyTree_OnSelectedItemChanged"
                  PreviewMouseRightButtonDown="HierarchyTree_OnPreviewMouseRightButtonDown"
                  MouseRightButtonUp="HierarchyTree_OnMouseRightButtonUp"
                  PreviewMouseLeftButtonDown="HierarchyTree_OnPreviewMouseLeftButtonDown"
                  PreviewMouseMove="HierarchyTree_OnPreviewMouseMove"
                  ContextMenuOpening="HierarchyTree_OnContextMenuOpening"
                  DragOver="HierarchyTree_OnDragOver"
                  Drop="HierarchyTree_OnDrop">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type local:MapHierarchyItem}" ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding IsVisible}" Visibility="{Binding LayerIndex, Converter={StaticResource LayerIndexToVisibility}}"
                                  ToolTip="Mostrar/Ocultar capa" Margin="0,0,4,0" Click="LayerVisibilityCheckBox_OnClick"/>
                        <TextBlock Text="{Binding Icon}" Width="18" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
