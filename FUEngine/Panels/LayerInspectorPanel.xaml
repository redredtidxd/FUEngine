<UserControl x:Class="FUEngine.LayerInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False">
        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Propiedades de la capa" FontWeight="SemiBold" FontSize="13" Foreground="#e6edf3" Margin="0,0,0,10"/>
            <Border Background="#21262d" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="ID (interno)" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxtId" Foreground="#6e7681" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="Nombre" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtName" Foreground="#e6edf3" Background="#0d1117" BorderBrush="#30363d" Padding="6,4" Margin="0,0,0,8" TextChanged="TxtName_OnTextChanged"/>
                    <TextBlock Text="Tipo de capa" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <ComboBox x:Name="CmbLayerType" Foreground="#e6edf3" Background="#21262d" BorderBrush="#30363d" Padding="6,4" Margin="0,0,0,8"
                              SelectionChanged="CmbLayerType_OnSelectionChanged"/>
                    <TextBlock Text="Opacidad (%)" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SliderOpacity" Minimum="0" Maximum="100" Value="100" Margin="0,0,8,0"
                                ValueChanged="SliderOpacity_OnValueChanged"/>
                        <TextBlock x:Name="TxtOpacityValue" Grid.Column="1" Text="100" Foreground="#8b949e" FontSize="10" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="Modo de mezcla" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <ComboBox x:Name="CmbBlendMode" Foreground="#e6edf3" Background="#21262d" BorderBrush="#30363d" Padding="6,4" Margin="0,0,0,8"
                              SelectionChanged="CmbBlendMode_OnSelectionChanged"/>
                    <TextBlock Text="Parallax X" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtParallaxX" Foreground="#e6edf3" Background="#0d1117" BorderBrush="#30363d" Padding="6,4" Margin="0,0,0,4" LostFocus="TxtParallax_OnLostFocus"/>
                    <TextBlock Text="Parallax Y" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtParallaxY" Foreground="#e6edf3" Background="#0d1117" BorderBrush="#30363d" Padding="6,4" Margin="0,0,0,8" LostFocus="TxtParallax_OnLostFocus"/>
                    <TextBlock Text="Offset X (px)" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtOffsetX" Foreground="#e6edf3" Background="#0d1117" BorderBrush="#30363d" Padding="6,4" Margin="0,0,0,4" LostFocus="TxtOffset_OnLostFocus"/>
                    <TextBlock Text="Offset Y (px)" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtOffsetY" Foreground="#e6edf3" Background="#0d1117" BorderBrush="#30363d" Padding="6,4" Margin="0,0,0,8" LostFocus="TxtOffset_OnLostFocus"/>
                    <TextBlock Text="Colisión y render" Foreground="#e6edf3" FontWeight="SemiBold" FontSize="11" Margin="0,8,0,4"/>
                    <TextBlock Text="CollisionLayer (máscara)" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtCollisionLayer" Foreground="#e6edf3" Background="#0d1117" BorderBrush="#30363d" Padding="6,4" Margin="0,0,0,4" LostFocus="TxtCollision_OnLostFocus" ToolTip="Máscara de bits (ej. 1, 2, 4)"/>
                    <TextBlock Text="CollisionMask (con qué colisiona)" Foreground="#8b949e" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtCollisionMask" Foreground="#e6edf3" Background="#0d1117" BorderBrush="#30363d" Padding="6,4" Margin="0,0,0,6" LostFocus="TxtCollision_OnLostFocus" ToolTip="Máscara de bits"/>
                    <CheckBox x:Name="ChkRenderAbovePlayer" Content="Dibujar encima del jugador" Foreground="#e6edf3" Margin="0,0,0,12" Checked="ChkRenderAbovePlayer_OnChanged" Unchecked="ChkRenderAbovePlayer_OnChanged"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
