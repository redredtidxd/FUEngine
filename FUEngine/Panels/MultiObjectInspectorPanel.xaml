<UserControl x:Class="FUEngine.MultiObjectInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="INSPECTOR · Varios objetos" FontWeight="Bold" FontSize="12" Foreground="#8b949e" Margin="0,0,0,10"/>
            <Border Background="#21262d" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Propiedades comunes" FontWeight="SemiBold" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtCount" Text="0 objetos seleccionados" Foreground="#8b949e" FontSize="11" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtCommonInfo" Text="Edición masiva: los cambios se aplican a todos." Foreground="#6e7681" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"/>
                </StackPanel>
            </Border>
            <Border Background="#21262d" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Rotación (a todos)" FontWeight="SemiBold" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <Button x:Name="BtnRotate90" Content="+90°" Padding="8,4" Margin="0,0,4,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Click="BtnRotate_OnClick" Tag="90"/>
                        <Button x:Name="BtnRotate180" Content="+180°" Padding="8,4" Margin="0,0,4,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Click="BtnRotate_OnClick" Tag="180"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Background="#21262d" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Acciones" FontWeight="SemiBold" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,6"/>
                    <Button x:Name="BtnDeselectAll" Content="Deseleccionar todo" Padding="8,4" Margin="0,0,0,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Click="BtnDeselectAll_OnClick"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
