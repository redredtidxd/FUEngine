<UserControl x:Class="FUEngine.PlayHierarchyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#161b22">
    <Border Background="#1a1f26" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="60"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#21262d" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                <TextBlock Text="Objetos en Play" FontWeight="SemiBold" FontSize="12" Foreground="#a371f7"/>
            </Border>
            <ListBox Grid.Row="1" x:Name="ObjectList" Background="Transparent" Foreground="#e6edf3" BorderThickness="0"
                     FontSize="11" Margin="4,4,4,8"/>
        </Grid>
    </Border>
</UserControl>
