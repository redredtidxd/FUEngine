<UserControl x:Class="FUEngine.TriggerZoneInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="INSPECTOR · Trigger Zone" FontWeight="Bold" FontSize="12" Foreground="#8b949e" Margin="0,0,0,10"/>
            <!-- Propiedades básicas -->
            <Border Background="#21262d" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Propiedades básicas" FontWeight="SemiBold" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,6"/>
                    <TextBlock Text="Nombre" Foreground="#8b949e" FontSize="11" Margin="0,4,0,2"/>
                    <TextBox x:Name="TxtNombre" Padding="8,6" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,0,0,6" TextChanged="TxtNombre_OnTextChanged"/>
                    <TextBlock Text="Descripción" Foreground="#8b949e" FontSize="11" Margin="0,2,0,2"/>
                    <TextBox x:Name="TxtDescripcion" Padding="8,6" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,0,0,6" TextChanged="TxtDescripcion_OnTextChanged" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40"/>
                    <TextBlock Text="Tipo" Foreground="#8b949e" FontSize="11" Margin="0,2,0,2"/>
                    <ComboBox x:Name="CmbTriggerType" Padding="6,4" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,0,0,6" SelectionChanged="CmbTriggerType_OnSelectionChanged"/>
                    <TextBlock Text="Capa (layer)" Foreground="#8b949e" FontSize="11" Margin="0,2,0,2"/>
                    <TextBox x:Name="TxtLayerId" Padding="6,4" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,0,0,8" TextChanged="TxtLayerId_OnTextChanged"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="X (tiles)" Foreground="#8b949e" FontSize="11"/>
                            <TextBox x:Name="TxtX" Padding="6,4" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,2,0,4" TextChanged="TxtPositionSize_OnTextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock Text="Y (tiles)" Foreground="#8b949e" FontSize="11"/>
                            <TextBox x:Name="TxtY" Padding="6,4" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,2,0,4" TextChanged="TxtPositionSize_OnTextChanged"/>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="Ancho" Foreground="#8b949e" FontSize="11"/>
                            <TextBox x:Name="TxtWidth" Padding="6,4" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,2,0,4" TextChanged="TxtPositionSize_OnTextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock Text="Alto" Foreground="#8b949e" FontSize="11"/>
                            <TextBox x:Name="TxtHeight" Padding="6,4" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,2,0,4" TextChanged="TxtPositionSize_OnTextChanged"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            <!-- Configuración: scripts -->
            <Border Background="#21262d" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Eventos / Scripts" FontWeight="SemiBold" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,6"/>
                    <TextBlock Text="onEnter (al entrar)" Foreground="#8b949e" FontSize="11" Margin="0,2,0,2"/>
                    <ComboBox x:Name="CmbScriptEnter" Padding="6,4" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,0,0,6" SelectionChanged="CmbScript_OnSelectionChanged"/>
                    <TextBlock Text="onExit (al salir)" Foreground="#8b949e" FontSize="11" Margin="0,2,0,2"/>
                    <ComboBox x:Name="CmbScriptExit" Padding="6,4" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,0,0,6" SelectionChanged="CmbScript_OnSelectionChanged"/>
                    <TextBlock Text="onTick (continuo)" Foreground="#8b949e" FontSize="11" Margin="0,2,0,2"/>
                    <ComboBox x:Name="CmbScriptTick" Padding="6,4" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,0,0,6" SelectionChanged="CmbScript_OnSelectionChanged"/>
                    <TextBlock Text="Tags (separados por coma)" Foreground="#8b949e" FontSize="11" Margin="0,2,0,2"/>
                    <TextBox x:Name="TxtTags" Padding="6,4" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" Margin="0,0,0,0" TextChanged="TxtTags_OnTextChanged"/>
                </StackPanel>
            </Border>
            <!-- Acciones rápidas -->
            <Border Background="#21262d" CornerRadius="4" Padding="10,8" Margin="0,0,0,8" HorizontalAlignment="Left" MaxWidth="220">
                <StackPanel>
                    <TextBlock Text="Acciones rápidas" FontWeight="SemiBold" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,6"/>
                    <Button x:Name="BtnDuplicate" Content="Duplicar" Padding="8,4" Margin="0,0,0,4" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Click="BtnDuplicate_OnClick"/>
                    <Button x:Name="BtnDelete" Content="Eliminar" Padding="8,4" Margin="0,0,0,4" Background="#da3633" Foreground="White" BorderThickness="0" Click="BtnDelete_OnClick"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
