<UserControl x:Class="FUEngine.Spotlight.SpotlightControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="SpotlightControl_Loaded"
             PreviewKeyDown="SpotlightControl_PreviewKeyDown">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TxtIndexTotals" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Foreground="#8b949e" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,6"/>
        <TextBlock x:Name="TxtMatchTotals" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                   Foreground="#58a6ff" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <TextBox x:Name="TxtQuery" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                 Padding="10,8" FontSize="14" Margin="0,0,0,10"
                 Background="#161b22" Foreground="#e6edf3" BorderBrush="#30363d" CaretBrush="#e6edf3"
                 TextChanged="TxtQuery_OnTextChanged"/>
        <ListBox x:Name="ResultList" Grid.Row="3" Grid.Column="0"
                 Background="#161b22" BorderBrush="#30363d" Foreground="#e6edf3"
                 MouseDoubleClick="ResultList_OnMouseDoubleClick"
                 SelectionChanged="ResultList_OnSelectionChanged">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                <TextBlock Text="{Binding Name}" Foreground="#58a6ff" FontWeight="SemiBold" FontSize="11"/>
                                <TextBlock Foreground="#6e7681" FontSize="10" Margin="6,0,0,0"
                                           Text="{Binding ItemCount, StringFormat=' ({0})'}"/>
                            </StackPanel>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2,4">
                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock FontSize="11" Foreground="#8b949e" Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock FontSize="10" Foreground="#6e7681" Text="{Binding CategoryLabel}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Border Grid.Row="3" Grid.Column="1" Background="#161b22" BorderBrush="#30363d" BorderThickness="1" Padding="8" Margin="8,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="TxtDetailTitle" Foreground="#58a6ff" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtDetailBody" Foreground="#e6edf3" FontSize="11" TextWrapping="Wrap"/>
                    <TextBlock x:Name="LblExample" Text="Ejemplo" Foreground="#8b949e" FontSize="10" Margin="0,8,0,2" Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtDetailExample" Foreground="#d29922" FontSize="10" FontFamily="Consolas" TextWrapping="Wrap" Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Foreground="#6e7681" FontSize="10" Margin="0,8,0,0"
                   Text="↑↓ seleccionar · Enter o doble clic abre (Lua → tema del manual relacionado) · Esc cerrar"/>
    </Grid>
</UserControl>
