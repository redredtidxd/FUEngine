<UserControl x:Class="FUEngine.DocumentationHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine">
    <TabControl x:Name="DocTabs" Background="#0d1117" BorderThickness="0">
        <TabItem Header="Manual del motor" ToolTip="Editor, mapa, Play, archivos JSON y flujo de trabajo (sin la lista larga de palabras reservadas Lua).">
            <local:DocumentationView x:Name="ManualDocView" RequestClose="Child_RequestClose"/>
        </TabItem>
        <TabItem Header="Lua — sintaxis y librería" ToolTip="Palabras reservadas, guías de librería estándar y patrones que cruzan con FUEngine (hooks, require, sandbox).">
            <local:DocumentationView x:Name="LuaDocView" RequestClose="Child_RequestClose"/>
        </TabItem>
        <TabItem Header="Ejemplos de scripts" ToolTip="Snippets Lua listos para copiar o crear .lua; categorías y dificultad en la lista.">
            <local:DocumentationView x:Name="ExamplesDocView" RequestClose="Child_RequestClose"/>
        </TabItem>
    </TabControl>
</UserControl>
