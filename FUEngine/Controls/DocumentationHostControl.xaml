<UserControl x:Class="FUEngine.DocumentationHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border x:Name="DocChromeBar" Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel LastChildFill="True">
                <Button x:Name="BtnOpenDocDetached" DockPanel.Dock="Right" Content="Ventana aparte" Padding="10,5" Margin="8,0,0,0"
                        Background="#21262d" Foreground="#58a6ff" BorderBrush="#30363d" Cursor="Hand"
                        Click="BtnOpenDocDetached_OnClick"
                        ToolTip="Abre el manual en una ventana independiente (misma pestaña y tema activos)."/>
                <TextBlock Text="Documentación integrada" VerticalAlignment="Center" Foreground="#8b949e" FontSize="12"/>
            </DockPanel>
        </Border>
        <TabControl x:Name="DocTabs" Grid.Row="1" Background="#0d1117" BorderThickness="0">
        <TabItem Header="Manual del motor" ToolTip="Editor, mapa, Play, archivos JSON y flujo de trabajo (sin la lista larga de palabras reservadas Lua).">
            <local:DocumentationView x:Name="ManualDocView" RequestClose="Child_RequestClose"/>
        </TabItem>
        <TabItem Header="Lua — sintaxis y librería" ToolTip="Palabras reservadas, guías de librería estándar y patrones que cruzan con FUEngine (hooks, require, sandbox).">
            <local:DocumentationView x:Name="LuaDocView" RequestClose="Child_RequestClose"/>
        </TabItem>
        <TabItem Header="Ejemplos de scripts" ToolTip="Snippets Lua listos para copiar o crear .lua; categorías y dificultad en la lista.">
            <local:DocumentationView x:Name="ExamplesDocView" RequestClose="Child_RequestClose"/>
        </TabItem>
    </TabControl>
    </Grid>
</UserControl>
