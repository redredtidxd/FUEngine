<UserControl x:Class="FUEngine.MinimapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#21262d" BorderBrush="#30363d" BorderThickness="1">
    <Grid>
        <Viewbox Stretch="Uniform">
            <Canvas x:Name="MinimapCanvas" Width="128" Height="128" Background="#0d1117"/>
        </Viewbox>
        <TextBlock x:Name="TxtMinimapLabel" Text="Mini-mapa" FontSize="10" Foreground="#6e7681"
                   VerticalAlignment="Top" HorizontalAlignment="Left" Margin="4,2"/>
    </Grid>
</UserControl>
