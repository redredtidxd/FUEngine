<UserControl x:Class="FUEngine.DocumentationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine"
             >
    <Grid Margin="8,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" Content="Cerrar" Padding="12,6" Margin="12,0,0,0"
                    Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Cursor="Hand"
                    Click="BtnClose_OnClick" ToolTip="Cierra el panel (Esc)"/>
            <TextBlock x:Name="TxtMainTitle" Text="Documentación FUEngine" FontSize="18" FontWeight="SemiBold" Foreground="#e6edf3" VerticalAlignment="Center"/>
        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Índice ~14% (máx. 260 px); contenido ~86% — arrastra el separador para afinar -->
                <ColumnDefinition MinWidth="176" MaxWidth="260" Width="1*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition MinWidth="400" Width="6*"/>
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" LastChildFill="True" MinWidth="0">
                <TextBlock x:Name="TxtFilterLabel" DockPanel.Dock="Top" Text="Buscar en el índice" Foreground="#8b949e" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtFilter" DockPanel.Dock="Top" Padding="8,6" Margin="0,0,0,8"
                         Background="#161b22" Foreground="#e6edf3" BorderBrush="#30363d"
                         TextChanged="TxtFilter_OnTextChanged"
                         ToolTip="Filtra temas por título o contenido"/>
                <ListBox x:Name="TopicList"
                         Background="#161b22" Foreground="#e6edf3" BorderBrush="#30363d"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="False"
                         SelectionChanged="TopicList_OnSelectionChanged">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#58a6ff"
                                               FontWeight="SemiBold"
                                               FontSize="11"
                                               Margin="0,10,0,4"
                                               TextWrapping="Wrap"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="SnapsToDevicePixels" Value="True"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="RowBg" Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,5">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RowBg" Property="Background" Value="#1c2128"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RowBg" Property="Background" Value="#1f3d5c"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:DocumentationTopicListEntry}">
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DifficultyTier}" Value="{x:Static local:ScriptExampleDifficultyTier.Basic}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Fill" Value="#3fb950"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DifficultyTier}" Value="{x:Static local:ScriptExampleDifficultyTier.Intermediate}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Fill" Value="#d29922"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DifficultyTier}" Value="{x:Static local:ScriptExampleDifficultyTier.Advanced}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Fill" Value="#f85149"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Grid.Column="1" Text="{Binding DisplayLabel}" TextWrapping="Wrap" VerticalAlignment="Center"
                                           Foreground="#e6edf3" FontSize="13" LineHeight="18"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" Background="#30363d"
                          ResizeBehavior="PreviousAndNext" ShowsPreview="False"/>
            <Border Grid.Column="2" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" Padding="16,12" CornerRadius="8">
                <ScrollViewer x:Name="DetailScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="DetailPanel"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
