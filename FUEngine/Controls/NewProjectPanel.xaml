<UserControl x:Class="FUEngine.NewProjectPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0d1117">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Crear proyecto" FontSize="18" FontWeight="SemiBold" Foreground="#e6edf3" Margin="0,0,0,16"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Nombre del proyecto" Foreground="#8b949e" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtName" Margin="0,0,0,12" Padding="8,6" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" TextChanged="TxtName_OnTextChanged"/>
                <TextBlock Text="Descripción (opcional)" Foreground="#8b949e" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtDescription" Height="44" TextWrapping="Wrap" AcceptsReturn="True" Padding="8,6" Margin="0,0,0,12" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
                <TextBlock Text="Carpeta del proyecto" Foreground="#8b949e" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtPath" Grid.Column="0" Margin="0,0,8,0" Padding="8,6" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
                    <Button x:Name="BtnBrowse" Grid.Column="1" Content="..." Width="36" Height="28" Padding="0" Click="BtnBrowse_OnClick"/>
                </Grid>
                <CheckBox x:Name="ChkCreateFolder" Content="Crear la carpeta si no existe" IsChecked="True" Foreground="#e6edf3" Margin="0,0,0,16"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Width="90" Margin="0,0,10,0" Padding="12,8" Click="BtnCancel_OnClick"/>
            <Button Content="Crear" Width="90" IsDefault="True" Padding="12,8" Click="BtnCreate_OnClick"/>
        </StackPanel>
    </Grid>
</UserControl>
