<Window x:Class="FUEngine.CleanOrphansDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Limpiar archivos huérfanos" Height="420" Width="620"
        WindowStartupLocation="CenterOwner"
        Background="#161b22" Foreground="#e6edf3"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Estos archivos no están referenciados por ninguna escena. Marca solo los que quieras eliminar (ruta completa)."
                  TextWrapping="Wrap" Foreground="#8b949e" Margin="0,0,0,10"/>
        <Border Grid.Row="1" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" Padding="4">
            <ListBox x:Name="LstOrphans" Background="Transparent" Foreground="#e6edf3" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionMode="Extended">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Foreground="#e6edf3" Margin="0,2">
                            <TextBlock Text="{Binding FullPath}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip="{Binding FullPath}" FontSize="11"/>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Seleccionar todo" Padding="10,6" Margin="0,0,8,0" Click="BtnSelectAll_OnClick" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
            <Button Content="Quitar selección" Padding="10,6" Margin="0,0,8,0" Click="BtnSelectNone_OnClick" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
            <Button Content="Cancelar" Padding="12,6" Margin="0,0,10,0" IsCancel="True" Click="BtnCancel_OnClick" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
            <Button x:Name="BtnDelete" Content="Eliminar seleccionados" Padding="12,6" Click="BtnDelete_OnClick" Background="#da3633" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
