<Window x:Class="FUEngine.TemplatePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elegir plantilla" Height="520" Width="760"
        WindowStartupLocation="CenterOwner"
        Background="#0d1117"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Selecciona una plantilla para tu proyecto" 
                       FontSize="15" Foreground="#e6edf3" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="Filtro:" Foreground="#8b949e" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="FilterCategory" Width="140" Background="#161b22" Foreground="#e6edf3" BorderBrush="#30363d"
                          SelectionChanged="FilterCategory_SelectionChanged"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ListBox x:Name="TemplateList" Grid.Column="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="1"
                     Foreground="#e6edf3" SelectionMode="Single" SelectionChanged="TemplateList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="#e6edf3"/>
                            <TextBlock Text="{Binding Description}" Foreground="#8b949e" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0" MaxHeight="36"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Grid.Column="1" Background="#30363d" Width="1"/>
            <Border Grid.Column="2" Background="#161b22" Padding="12" BorderBrush="#30363d" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Vista previa" FontWeight="SemiBold" Foreground="#e6edf3" FontSize="12" Margin="0,0,0,8"/>
                    <Border Grid.Row="1" Background="#0d1117" CornerRadius="4" Padding="4" Margin="0,0,0,12">
                        <Canvas x:Name="PreviewCanvas" Width="220" Height="160" ClipToBounds="True"/>
                    </Border>
                    <StackPanel Grid.Row="2">
                        <TextBlock x:Name="TxtScriptsIncluded" Text="Selecciona una plantilla para ver los scripts incluidos." 
                                   Foreground="#8b949e" FontSize="11" TextWrapping="Wrap"/>
                        <TextBlock Text="Próximamente: combinar plantillas (ej. top-down + sección lateral)." 
                                   Foreground="#6e7681" FontSize="10" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Width="90" Height="32" Click="BtnCancel_OnClick" Background="#21262d" BorderBrush="#30363d"/>
            <Button x:Name="BtnUse" Content="Usar plantilla" Width="120" Height="32" Margin="12,0,0,0" Click="BtnUse_OnClick" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
