<Window x:Class="FUEngine.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acerca de FUEngine" Height="420" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0d1117">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="FUEngine" FontSize="28" FontWeight="Bold" Foreground="#e6edf3" HorizontalAlignment="Center"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400" Margin="0,8,0,0">
                <TextBlock x:Name="TxtVersion" Text="Versión 0.0.1" Foreground="#8b949e" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
            </ScrollViewer>
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="220">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" Foreground="#8b949e" FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12">
                    Micro-motor pixel art para crear mapas, objetos, scripts y animaciones. Ideado para proyectos como Freddy's UnWired y juegos 2D con tiles, capas y eventos.
                </TextBlock>
                <TextBlock x:Name="TxtLicense" TextWrapping="Wrap" Foreground="#6e7681" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="2" Content="Cerrar" Width="100" HorizontalAlignment="Center" Padding="12,8" Click="BtnCerrar_OnClick"
                Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
    </Grid>
</Window>
