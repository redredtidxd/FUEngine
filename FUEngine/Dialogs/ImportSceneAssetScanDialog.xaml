<Window x:Class="FUEngine.ImportSceneAssetScanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Referencias de assets — Importar Scene" Height="440" Width="580"
        WindowStartupLocation="CenterOwner"
        Background="#161b22" Foreground="#e6edf3"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="La escena referencia estos assets. Tipo: imagen, sonido, etc. Solo se copian mapa y objetos; usa «Copiar encontrados» para traer los archivos."
                  TextWrapping="Wrap" Foreground="#8b949e" Margin="0,0,0,10"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="✅ Encontrados" Foreground="#3fb950" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ListBox x:Name="LstFound" Background="#0d1117" Foreground="#8b949e" BorderBrush="#30363d" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                         DisplayMemberPath="DisplayText" ToolTip="Ruta relativa · tipo"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="❌ Faltantes" Foreground="#f85149" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ListBox x:Name="LstMissing" Background="#0d1117" Foreground="#8b949e" BorderBrush="#30363d" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                         DisplayMemberPath="DisplayText"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="BtnCopyAssets" Content="Copiar encontrados al proyecto" Padding="12,8" Margin="0,0,10,0" Click="BtnCopyAssets_OnClick"
                    Background="#1f6feb" Foreground="White" BorderThickness="0" ToolTip="Copia los assets encontrados a la carpeta Assets del proyecto actual"/>
            <Button Content="Cancelar" Padding="14,8" Margin="0,0,8,0" IsCancel="True" Click="BtnCancel_OnClick"
                    Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
            <Button x:Name="BtnImport" Content="Importar igual" Padding="14,8" Click="BtnImport_OnClick"
                    Background="#238636" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
