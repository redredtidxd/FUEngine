<Window x:Class="FUEngine.PixelEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar tile a nivel píxel" Height="420" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#161b22">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="TxtTitle" Text="Tile (0, 0) — 16×16 píxeles" Foreground="#e6edf3" FontSize="13" Margin="0,0,0,8"/>
        <Border Grid.Row="1" BorderBrush="#30363d" BorderThickness="1" Background="#21262d" Padding="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Color:" VerticalAlignment="Center" Foreground="#8b949e" Margin="0,0,6,0"/>
                <Border x:Name="BorderColor" Width="24" Height="24" Background="#808080" BorderBrush="#6e7681" BorderThickness="1" MouseLeftButtonDown="BorderColor_OnClick"/>
                <Button x:Name="BtnErase" Content="Goma" Width="60" Height="26" Margin="12,0,0,0" Click="BtnErase_OnClick" ToolTip="Borrar píxel (clic derecho también)"
                        Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
                <Button x:Name="BtnFill" Content="Relleno" Width="60" Height="26" Margin="4,0,0,0" Click="BtnFill_OnClick" ToolTip="Rellenar zona conectada"
                        Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
                <Button x:Name="BtnUndo" Content="Deshacer" Width="70" Height="26" Margin="8,0,0,0" Click="BtnUndo_OnClick"
                        Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
                <Button x:Name="BtnImageBase" Content="Imagen base..." Width="100" Height="26" Margin="8,0,0,0" Click="BtnImageBase_OnClick"
                        ToolTip="Usar un PNG/JPG como base del tile (en lugar del color)"
                        Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="2" BorderBrush="#30363d" BorderThickness="1" Background="#0d1117" Padding="4">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid x:Name="PixelGrid" MouseLeftButtonDown="PixelGrid_OnMouseDown" MouseRightButtonDown="PixelGrid_OnMouseDown" MouseMove="PixelGrid_OnMouseMove" MouseLeftButtonUp="PixelGrid_OnMouseUp" MouseRightButtonUp="PixelGrid_OnMouseUp"/>
            </ScrollViewer>
        </Border>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnCancel" Content="Cancelar" Width="90" Height="28" Margin="0,0,8,0" Click="BtnCancel_OnClick"
                    Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
            <Button x:Name="BtnSave" Content="Guardar" Width="90" Height="28" Click="BtnSave_OnClick"
                    Background="#238636" Foreground="White" BorderBrush="#2ea043"/>
        </StackPanel>
    </Grid>
</Window>
