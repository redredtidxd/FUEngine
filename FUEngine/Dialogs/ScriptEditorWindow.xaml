<Window x:Class="FUEngine.ScriptEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editor de código - FUEngine" Height="520" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#0d1117"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Barra de archivo -->
        <Border Grid.Row="0" Background="#161b22" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <TextBlock x:Name="TxtFileName" Text="" Foreground="#8b949e" FontSize="12" FontFamily="Consolas"/>
        </Border>
        <!-- Área de edición tipo IDE -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" x:Name="LineNumberPanel" Background="#21262d" Padding="8,8,12,8" BorderBrush="#30363d" BorderThickness="0,0,1,0" MinWidth="44">
                <TextBlock x:Name="TxtLineNumbers" FontFamily="Consolas" FontSize="13" Foreground="#6e7681" VerticalAlignment="Top" Text="1"/>
            </Border>
            <TextBox x:Name="EditorTextBox" Grid.Column="1" 
                     AcceptsReturn="True" AcceptsTab="True" 
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="13" Padding="8"
                     Background="#0d1117" Foreground="#e6edf3" CaretBrush="#e6edf3"
                     BorderThickness="0" TextWrapping="NoWrap"
                     TextChanged="EditorTextBox_OnTextChanged"
                     KeyDown="EditorTextBox_OnKeyDown"/>
        </Grid>
        <!-- Barra inferior: estado y botones -->
        <Border Grid.Row="2" Background="#161b22" Padding="10,8" BorderBrush="#30363d" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtStatus" Text="Listo" Foreground="#8b949e" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtModified" Text=" ● Sin guardar" Foreground="#f85149" FontSize="11" Margin="12,0,0,0" Visibility="Collapsed"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnSave" Content="Guardar" Width="90" Height="28" Margin="0,0,8,0" Click="BtnSave_OnClick"
                            Background="#238636" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="BtnClose" Content="Cerrar" Width="80" Height="28" Click="BtnClose_OnClick"
                            Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
