<Window x:Class="FUEngine.SimulateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simulación" Height="480" Width="640"
        WindowStartupLocation="CenterOwner"
        Background="#0d1117" KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <TextBlock Text="Vista previa: flechas para mover. Cierra para volver al editor." Foreground="#8b949e" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtFps" Text="" Foreground="#6e7681" FontSize="11" Margin="16,0,0,0" VerticalAlignment="Center"/>
        </StackPanel> 
                   Foreground="#8b949e" Margin="8" FontSize="12"/>
        <Border Grid.Row="1" Background="#161b22" Margin="8">
            <Canvas x:Name="SimCanvas" ClipToBounds="True"/>
        </Border>
        <TextBlock x:Name="TxtLog" Grid.Row="2" Text="" Foreground="#e6edf3" Margin="8" FontSize="11" TextWrapping="Wrap"/>
    </Grid>
</Window>
