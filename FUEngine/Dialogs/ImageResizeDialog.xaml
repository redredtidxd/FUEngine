<Window x:Class="FUEngine.ImageResizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reescalar imagen" Height="Auto" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#161b22" Foreground="#e6edf3">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TxtInfo" Grid.Row="0" TextWrapping="Wrap" Foreground="#8b949e" FontSize="12" Margin="0,0,0,12"/>
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ancho" VerticalAlignment="Center" Margin="0,0,12,8"/>
            <TextBox x:Name="TxtWidth" Grid.Row="0" Grid.Column="1" Padding="8,6" Margin="0,0,0,8"
                     Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" TextChanged="TxtSize_OnTextChanged"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Alto" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBox x:Name="TxtHeight" Grid.Row="1" Grid.Column="1" Padding="8,6"
                     Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d" TextChanged="TxtSize_OnTextChanged"/>
        </Grid>
        <CheckBox x:Name="ChkAspect" Grid.Row="2" Content="Mantener proporción" IsChecked="True" Foreground="#e6edf3" Margin="0,0,0,8"
                  Checked="ChkAspect_OnChanged" Unchecked="ChkAspect_OnChanged"/>
        <CheckBox x:Name="ChkSnapTile" Grid.Row="3" Content="Ajustar ancho y alto al múltiplo del tile del proyecto" Foreground="#e6edf3" Margin="0,0,0,8"
                  ToolTip="Usa TileSize del Project.FUE / JSON (si existe)."/>
        <StackPanel Grid.Row="4" Orientation="Vertical">
            <TextBlock Text="Presets rápidos" Foreground="#8b949e" FontSize="11" Margin="0,0,0,6"/>
            <WrapPanel Margin="0,0,0,10">
                <Button Content="×2" Padding="10,6" Margin="0,0,6,6" Click="BtnScale_OnClick" Tag="2" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Cursor="Hand"/>
                <Button Content="×4" Padding="10,6" Margin="0,0,6,6" Click="BtnScale_OnClick" Tag="4" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Cursor="Hand"/>
                <Button Content="÷2" Padding="10,6" Margin="0,0,6,6" Click="BtnScale_OnClick" Tag="0.5" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Cursor="Hand"/>
                <Button x:Name="BtnSnapTile" Content="Snap tile" Padding="10,6" Margin="0,0,6,6" Click="BtnSnapTile_OnClick" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Cursor="Hand"
                        ToolTip="Redondea dimensiones al múltiplo más cercano del tamaño de tile."/>
            </WrapPanel>
            <TextBlock x:Name="TxtHint" TextWrapping="Wrap" Foreground="#8b949e" FontSize="11" Margin="0,0,0,12"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Padding="14,8" Margin="0,0,8,0" IsCancel="True" Click="BtnCancel_OnClick"
                        Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d"/>
                <Button Content="Guardar como copia…" Padding="14,8" Margin="0,0,8,0" Click="BtnSaveCopy_OnClick"
                        Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Cursor="Hand"
                        ToolTip="Crea un archivo nuevo sin sobrescribir el original."/>
                <Button Content="Aplicar (sobrescribir)" Padding="14,8" Click="BtnOverwrite_OnClick"
                        Background="#238636" Foreground="White" BorderThickness="0" Cursor="Hand"
                        ToolTip="Sustituye el archivo en disco. Recomendado hacer copia antes si no tienes backup."/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
