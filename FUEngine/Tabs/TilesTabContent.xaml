<UserControl x:Class="FUEngine.TilesTabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             Background="#161b22">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#21262d" Padding="8" BorderBrush="#30363d" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Paleta de tiles" FontWeight="SemiBold" Foreground="#e6edf3" Margin="0,0,0,8"/>
                <ListBox x:Name="TilesList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         SelectionChanged="TilesList_OnSelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <primitives:UniformGrid Columns="4"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="CellBorder" Background="#30363d" CornerRadius="2" Cursor="Hand"
                                                BorderBrush="#58a6ff" BorderThickness="0"
                                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                MinWidth="48" MinHeight="48" Width="48" Height="48">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                            <Setter Property="BorderBrush" Value="#58a6ff"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding}" Foreground="#e6edf3" FontSize="12"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>
        <Border Grid.Column="1" Margin="16" Background="#0d1117" Padding="12">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Tiles y Tilesets" FontSize="16" FontWeight="SemiBold" Foreground="#e6edf3" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Selecciona un tile en la paleta para ver propiedades en el Inspector. Importa un tileset en el editor para cargar miniaturas." 
                           Foreground="#8b949e" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                <Button x:Name="BtnOpenTilesetEditor" Content="Abrir editor de Tileset" Padding="16,10" 
                        Background="#238636" Foreground="White" BorderThickness="0" FontWeight="SemiBold"
                        HorizontalAlignment="Center" Click="BtnOpenTilesetEditor_OnClick"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
