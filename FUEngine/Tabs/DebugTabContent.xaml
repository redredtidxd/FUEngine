<UserControl x:Class="FUEngine.DebugTabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0d1117">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Runtime Info -->
        <Border Grid.Row="0" x:Name="PanelRuntimeInfo" Background="#21262d" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtRuntimeSource" Text="Sin runtime activo" Foreground="#8b949e" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtFps" Text="FPS: —" Foreground="#58a6ff" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtFrame" Text="Frame: 0" Foreground="#8b949e" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtDelta" Text="dt: — ms" Foreground="#8b949e" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtObjects" Text="Objetos: 0" Foreground="#8b949e" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtScripts" Text="Scripts: 0" Foreground="#8b949e" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtLuaMem" Text="Lua: — KB" Foreground="#8b949e" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtMemory" Text="Memory: —" Foreground="#8b949e" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtDrawCalls" Text="Draw: —" Foreground="#8b949e" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtAudioChannels" Text="Audio: —" Foreground="#8b949e" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock x:Name="TxtBreakpointPaused" Text="" Foreground="#f85149" FontSize="11" Margin="0,0,8,0" Visibility="Collapsed"/>
                <Button x:Name="BtnResumeBreakpoint" Content="Reanudar" Padding="8,4" Background="#238636" Foreground="White" BorderThickness="0" Visibility="Collapsed" Click="BtnResumeBreakpoint_OnClick"/>
            </StackPanel>
        </Border>
        <!-- Scene Objects | Inspector | Script Variables | Eventos | Colisiones | Breakpoints -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" MinWidth="100"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="200" MinWidth="140"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="180" MinWidth="120"/>
            </Grid.ColumnDefinitions>
            <!-- Scene Objects -->
            <Border Grid.Column="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#21262d" Padding="6,4" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                        <TextBlock Text="Scene Objects" FontWeight="SemiBold" FontSize="12" Foreground="#a371f7"/>
                    </Border>
                    <ListBox Grid.Row="1" x:Name="SceneObjectsList" Background="Transparent" Foreground="#e6edf3" BorderThickness="0"
                             FontSize="11" Margin="4" DisplayMemberPath="Name" SelectionChanged="SceneObjectsList_OnSelectionChanged"/>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#30363d"/>
            <!-- Inspector -->
            <Border Grid.Column="2" Background="#161b22" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="InspectorTitle" Text="Inspector — Selecciona un objeto" Foreground="#8b949e" FontSize="11" Margin="0,0,0,6"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="InspectorContent"/>
                    </ScrollViewer>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Background="#30363d"/>
            <!-- Script Variables -->
            <Border Grid.Column="4" Background="#161b22" BorderBrush="#30363d" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#21262d" Padding="6,4" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                        <TextBlock Text="Script Variables" FontWeight="SemiBold" FontSize="12" Foreground="#58a6ff"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4">
                        <StackPanel x:Name="ScriptVarsContent"/>
                    </ScrollViewer>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="5" Width="4" HorizontalAlignment="Stretch" Background="#30363d"/>
            <!-- Eventos + Colisiones + Breakpoints -->
            <Border Grid.Column="6" Background="#161b22" BorderBrush="#30363d" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#21262d" Padding="6,4" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                        <TextBlock Text="Eventos" FontWeight="SemiBold" FontSize="12" Foreground="#a371f7"/>
                    </Border>
                    <ListBox Grid.Row="1" x:Name="EventosList" Background="Transparent" Foreground="#e6edf3" BorderThickness="0" FontSize="10" Margin="4"/>
                    <Border Grid.Row="2" Background="#21262d" Padding="6,4" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                        <TextBlock Text="Colisiones" FontWeight="SemiBold" FontSize="12" Foreground="#79c0ff"/>
                    </Border>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="4,2">
                        <CheckBox x:Name="ChkShowColliders" Content="Colliders" Foreground="#e6edf3" FontSize="10" IsChecked="True" Checked="CollisionFilter_Changed" Unchecked="CollisionFilter_Changed"/>
                        <CheckBox x:Name="ChkShowHitboxes" Content="Hitboxes" Foreground="#e6edf3" FontSize="10" IsChecked="True" Margin="8,0,0,0" Checked="CollisionFilter_Changed" Unchecked="CollisionFilter_Changed"/>
                        <CheckBox x:Name="ChkShowTriggers" Content="Triggers" Foreground="#e6edf3" FontSize="10" IsChecked="True" Margin="8,0,0,0" Checked="CollisionFilter_Changed" Unchecked="CollisionFilter_Changed"/>
                    </StackPanel>
                    <ListBox Grid.Row="4" x:Name="ColisionesList" Background="Transparent" Foreground="#e6edf3" BorderThickness="0" FontSize="10" Margin="4"/>
                    <Border Grid.Row="5" Background="#21262d" Padding="6,4" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                        <TextBlock Text="Breakpoints" FontWeight="SemiBold" FontSize="12" Foreground="#f85149"/>
                    </Border>
                    <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="4,2">
                        <TextBox x:Name="TxtBreakpointPath" Width="90" Height="22" FontSize="10" Padding="2" ToolTip="Ruta relativa (ej: Scripts/Player.lua)"/>
                        <TextBox x:Name="TxtBreakpointLine" Width="36" Height="22" FontSize="10" Padding="2" Margin="4,0,0,0" ToolTip="Línea"/>
                        <Button x:Name="BtnAddBreakpoint" Content="+" Width="24" Height="22" Padding="0" Margin="4,0,0,0" Click="BtnAddBreakpoint_OnClick"/>
                    </StackPanel>
                    <ListBox Grid.Row="7" x:Name="BreakpointsList" Background="Transparent" Foreground="#e6edf3" BorderThickness="0" FontSize="10" Margin="4"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
