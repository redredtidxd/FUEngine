<UserControl x:Class="FUEngine.UITabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#161b22">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#21262d" BorderBrush="#30363d" BorderThickness="0,0,1,0" Padding="8">
            <StackPanel>
                <TextBlock x:Name="TxtCanvasName" Text="Canvas" FontWeight="SemiBold" Foreground="#e6edf3" Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtResolution" Text="1920×1080" Foreground="#8b949e" Margin="0,0,0,8"/>
                <TextBlock Text="Elementos" Foreground="#8b949e" Margin="0,4,0,4"/>
                <ListBox x:Name="ElementsList" Background="Transparent" Foreground="#e6edf3" BorderThickness="0"
                         DisplayMemberPath="Display" SelectionChanged="ElementsList_OnSelectionChanged" MinHeight="120"/>
            </StackPanel>
        </Border>
        <Border Grid.Column="1" Margin="8" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1">
            <Canvas x:Name="DesignSurface" ClipToBounds="True" Background="#0d1117"
                    SizeChanged="DesignSurface_OnSizeChanged" Loaded="DesignSurface_OnLoaded"/>
        </Border>
    </Grid>
</UserControl>
