<UserControl x:Class="FUEngine.AnimationsTabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine"
             Background="#161b22">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#21262d" Padding="12,8" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Animaciones · Listado por objeto/tile. Crear, renombrar, eliminar. Propiedades en Inspector." 
                           Foreground="#8b949e" FontSize="12"/>
                <Button x:Name="BtnCreateAnimation" Content="Crear animación" Margin="16,0,0,0" Padding="8,4" 
                        Click="BtnCreateAnimation_OnClick" Background="#238636" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ListBox x:Name="AnimationsList" Grid.Column="0" Background="#21262d" Foreground="#e6edf3" 
                         BorderThickness="0" SelectionChanged="AnimationsList_OnSelectionChanged"/>
                <Border Grid.Column="1" Margin="12,0,0,0" Background="#0d1117" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TxtAnimationPreview" Grid.Row="0" 
                                   Text="Selecciona una animación para ver preview y propiedades en el Inspector." 
                                   Foreground="#8b949e" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400" Margin="0,0,0,12"/>
                        <Border x:Name="PreviewArea" Grid.Row="1" Background="#21262d" CornerRadius="4" Padding="16" 
                                MinHeight="120" Margin="0,0,0,12" BorderBrush="#30363d" BorderThickness="1">
                            <Grid>
                                <TextBlock x:Name="TxtPreviewFrame" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#58a6ff" FontSize="14" FontWeight="SemiBold" Text=""/>
                                <StackPanel x:Name="PreviewPlayHint" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4">
                                    <TextBlock Text="Preview · " Foreground="#6e7681" FontSize="11"/>
                                    <TextBlock x:Name="TxtPreviewFps" Text="" Foreground="#8b949e" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="FramesStrip">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="56" Height="56" Margin="4" Background="#30363d" CornerRadius="2" 
                                                BorderBrush="#484f58" BorderThickness="1">
                                            <TextBlock Text="{Binding}" Foreground="#8b949e" FontSize="10" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
