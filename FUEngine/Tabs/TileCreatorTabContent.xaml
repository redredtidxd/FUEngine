<UserControl x:Class="FUEngine.TileCreatorTabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine"
             Background="#161b22">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#21262d" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="ChkAnimation" Content="Animación" Foreground="#e6edf3" VerticalAlignment="Center" Margin="0,0,12,0" Checked="AnimationMode_Changed" Unchecked="AnimationMode_Changed"/>
                <Separator Margin="4,0" Width="2" Background="#30363d"/>
                <TextBlock Text="Tamaño:" VerticalAlignment="Center" Foreground="#e6edf3" Margin="0,0,6,0"/>
                <RadioButton x:Name="Rb16" Content="16×16" GroupName="GridSize" IsChecked="True" Foreground="#e6edf3" VerticalAlignment="Center" Margin="0,0,12,0" Checked="GridSize_Changed"/>
                <RadioButton x:Name="Rb32" Content="32×32" GroupName="GridSize" Foreground="#e6edf3" VerticalAlignment="Center" Margin="0,0,16,0" Checked="GridSize_Changed"/>
                <Separator Margin="8,0" Width="2" Background="#30363d"/>
                <RadioButton x:Name="RbPencil" Content="✏" ToolTip="Lápiz" FontSize="15" GroupName="Tool" IsChecked="True" Foreground="#e6edf3" VerticalAlignment="Center" Margin="0,0,8,0" Checked="Tool_Checked"/>
                <RadioButton x:Name="RbEraser" Content="⌫" ToolTip="Goma" FontSize="15" GroupName="Tool" Foreground="#e6edf3" VerticalAlignment="Center" Margin="0,0,8,0" Checked="Tool_Checked"/>
                <RadioButton x:Name="RbFill" Content="▦" ToolTip="Relleno" FontSize="15" GroupName="Tool" Foreground="#e6edf3" VerticalAlignment="Center" Margin="0,0,16,0" Checked="Tool_Checked"/>
                <Separator Margin="8,0" Width="2" Background="#30363d"/>
                <Button x:Name="BtnNew" Content="Nuevo" Padding="10,4" Margin="0,0,8,0" Click="BtnNew_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#30363d"/>
                <Button x:Name="BtnSave" Content="Guardar..." Padding="10,4" Margin="0,0,8,0" Click="BtnSave_OnClick" Background="#238636" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>
        <Grid x:Name="ContentGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColAnimation" Width="0" MinWidth="0"/>
                <ColumnDefinition Width="Auto" MinWidth="120"/>
                <ColumnDefinition Width="Auto" MinWidth="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Panel Animación: frames, preview, Play/Stop, Duplicar, Eliminar, Agregar tile -->
            <Border x:Name="AnimationPanel" Grid.Column="0" Background="#21262d" Padding="8" BorderBrush="#30363d" BorderThickness="0,0,1,0" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Frames de la animación" FontWeight="SemiBold" Foreground="#e6edf3" Margin="0,0,0,8"/>
                    <ListBox x:Name="FramesList" MinHeight="100" SelectionChanged="FramesList_SelectionChanged" Background="#161b22" Foreground="#e6edf3" BorderThickness="0"/>
                    <TextBlock Text="Vista previa" Foreground="#8b949e" FontSize="10" Margin="0,8,0,4"/>
                    <Border Background="#0d1117" CornerRadius="4" Padding="4" MinHeight="80" BorderBrush="#30363d" BorderThickness="1">
                        <Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>
                    <TextBlock Text="FPS:" Foreground="#e6edf3" Margin="0,6,0,2"/>
                    <TextBox x:Name="TxtFps" Text="8" Width="48" Margin="0,0,0,8" VerticalContentAlignment="Center"/>
                    <Button x:Name="BtnPlayStop" Content="Reproducir" Padding="8,4" Margin="0,0,0,4" Click="BtnPlayStop_OnClick" Background="#238636" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="BtnDuplicateFrame" Content="Duplicar frame" Padding="8,4" Margin="0,0,0,4" Click="BtnDuplicateFrame_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#30363d"/>
                    <Button x:Name="BtnDeleteFrame" Content="Eliminar frame" Padding="8,4" Margin="0,0,0,4" Click="BtnDeleteFrame_OnClick" Background="#21262d" Foreground="#f85149" BorderBrush="#30363d"/>
                    <Button x:Name="BtnAddTileFromProject" Content="Agregar tile del proyecto" Padding="8,4" Margin="0,0,0,0" Click="BtnAddTileFromProject_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#30363d"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#21262d" Padding="8" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                <StackPanel>
                    <TextBlock Text="Paleta" FontWeight="SemiBold" Foreground="#e6edf3" Margin="0,0,0,8"/>
                    <WrapPanel x:Name="PalettePanel"/>
                    <Button x:Name="BtnAddColor" Content="+ Color" Margin="0,12,0,0" Padding="8,4" Click="BtnAddColor_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#30363d"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#21262d" Padding="8" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                <StackPanel>
                    <TextBlock Text="Capas" FontWeight="SemiBold" Foreground="#e6edf3" Margin="0,0,0,8"/>
                    <ListBox x:Name="LayersList" MinHeight="100" SelectionChanged="LayersList_SelectionChanged" Background="#161b22" Foreground="#e6edf3" BorderThickness="0"/>
                    <CheckBox x:Name="ChkLayerVisible" Content="Visible" Foreground="#e6edf3" Margin="0,6,0,0" Checked="ChkLayerVisible_Changed" Unchecked="ChkLayerVisible_Changed"/>
                    <Button x:Name="BtnAddLayer" Content="+ Capa" Margin="0,8,0,4" Padding="8,4" Click="BtnAddLayer_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#30363d"/>
                    <Button x:Name="BtnRemoveLayer" Content="− Capa" Margin="0,0,0,0" Padding="8,4" Click="BtnRemoveLayer_OnClick" Background="#21262d" Foreground="#f85149" BorderBrush="#30363d"/>
                </StackPanel>
            </Border>
            <local:DrawingCanvasControl x:Name="DrawingCanvas" Grid.Column="3" Margin="8"/>
        </Grid>
    </Grid>
</UserControl>
