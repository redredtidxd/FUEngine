<UserControl x:Class="FUEngine.AudioTabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0d1117">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Search + Filter -->
        <Border Grid.Row="0" Background="#21262d" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="SearchBox" Width="180" Height="24" FontSize="11" Padding="4,2" VerticalContentAlignment="Center"
                         ToolTip="Buscar por ID o nombre" Background="#161b22" Foreground="#e6edf3" BorderBrush="#30363d"/>
                <ComboBox x:Name="FilterType" Width="100" Height="24" Margin="8,0,0,0" FontSize="11" VerticalContentAlignment="Center"
                          Background="#161b22" Foreground="#e6edf3" BorderBrush="#30363d" SelectionChanged="FilterType_OnSelectionChanged"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="140"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- List -->
            <Border Grid.Column="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#21262d" Padding="6,4" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                        <TextBlock Text="Audio" FontWeight="SemiBold" FontSize="12" Foreground="#79c0ff"/>
                    </Border>
                    <ListBox Grid.Row="1" x:Name="AudioList" Background="Transparent" Foreground="#e6edf3" BorderThickness="0"
                             FontSize="11" Margin="4" SelectionChanged="AudioList_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding TypeIcon}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Id}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#30363d"/>
            <!-- Inspector -->
            <Border Grid.Column="2" Background="#161b22" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="InspectorTitle" Text="Inspector — Selecciona un sonido" Foreground="#8b949e" FontSize="11" Margin="0,0,0,8"/>
                        <TextBlock Text="Archivo:" Foreground="#8b949e" FontSize="11"/>
                        <TextBlock x:Name="TxtFile" Text="—" Foreground="#e6edf3" FontSize="11" Margin="0,2,0,8"/>
                        <TextBlock Text="Tipo:" Foreground="#8b949e" FontSize="11"/>
                        <TextBlock x:Name="TxtType" Text="—" Foreground="#e6edf3" FontSize="11" Margin="0,2,0,8"/>
                        <TextBlock Text="Duración:" Foreground="#8b949e" FontSize="11"/>
                        <TextBlock x:Name="TxtDuration" Text="—" Foreground="#e6edf3" FontSize="11" Margin="0,2,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                            <Button x:Name="BtnPreview" Content="▶ Preview" Padding="8,4" Margin="0,0,8,0" Background="#238636" Foreground="White" BorderThickness="0" Click="BtnPreview_OnClick"/>
                            <Button x:Name="BtnStop" Content="⏹ Stop" Padding="8,4" Margin="0,0,8,0" Background="#da3633" Foreground="White" BorderThickness="0" Click="BtnStop_OnClick"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="BtnReveal" Content="📂 Show File" Padding="8,4" Margin="0,0,8,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Click="BtnReveal_OnClick"/>
                            <Button x:Name="BtnCopyId" Content="Copy ID" Padding="8,4" Margin="0,0,8,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Click="BtnCopyId_OnClick"/>
                            <Button x:Name="BtnCopyLua" Content="Copy Lua" Padding="8,4" Margin="0,0,8,0" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" Click="BtnCopyLua_OnClick"/>
                            <Button x:Name="BtnPlayInGame" Content="▶ Play in Game" Padding="8,4" Background="#1f6feb" Foreground="White" BorderThickness="0" ToolTip="Reproduce en el runtime del juego (si está en ejecución)" Click="BtnPlayInGame_OnClick"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
