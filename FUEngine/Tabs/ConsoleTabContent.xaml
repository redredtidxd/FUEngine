<UserControl x:Class="FUEngine.ConsoleTabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine"
             Background="#161b22">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#21262d" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <TextBlock TextWrapping="Wrap" Foreground="#8b949e" FontSize="12"
                       Text="Consola unificada · Editor, Lua (print y errores NLua en Play), mapa y proyecto. Usa filtros y doble clic en errores con línea para abrir el script."/>
        </Border>
        <Border Grid.Row="1" Padding="4">
            <local:LogPanel/>
        </Border>
    </Grid>
</UserControl>
