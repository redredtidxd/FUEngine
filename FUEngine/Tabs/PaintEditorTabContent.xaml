<UserControl x:Class="FUEngine.PaintEditorTabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine"
             Background="#161b22">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#21262d" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtPath" Text="Editor de Pintura — Sin archivo" VerticalAlignment="Center" Foreground="#8b949e" Margin="0,0,16,0"/>
                <RadioButton x:Name="RbPencil" Content="✏" ToolTip="Lápiz" FontSize="15" GroupName="Tool" IsChecked="True" Foreground="#e6edf3" VerticalAlignment="Center" Margin="0,0,8,0" Checked="Tool_Checked"/>
                <RadioButton x:Name="RbEraser" Content="⌫" ToolTip="Goma" FontSize="15" GroupName="Tool" Foreground="#e6edf3" VerticalAlignment="Center" Margin="0,0,8,0" Checked="Tool_Checked"/>
                <RadioButton x:Name="RbFill" Content="▦" ToolTip="Relleno" FontSize="15" GroupName="Tool" Foreground="#e6edf3" VerticalAlignment="Center" Margin="0,0,12,0" Checked="Tool_Checked"/>
                <Separator Margin="8,0" Width="2" Background="#30363d"/>
                <TextBlock Text="Pincel:" VerticalAlignment="Center" Foreground="#e6edf3" Margin="0,0,6,0"/>
                <TextBox x:Name="TxtBrushSize" Text="4" Width="36" Margin="0,0,8,0" VerticalContentAlignment="Center" LostFocus="TxtBrushSize_LostFocus"/>
                <TextBlock Text="Opacidad:" VerticalAlignment="Center" Foreground="#e6edf3" Margin="0,0,6,0"/>
                <Slider x:Name="SliderOpacity" Minimum="0.1" Maximum="1" Value="1" Width="80" VerticalAlignment="Center" Margin="0,0,16,0" ValueChanged="SliderOpacity_ValueChanged"/>
                <Button x:Name="BtnSave" Content="Guardar" Padding="10,4" Margin="0,0,8,0" Click="BtnSave_OnClick" Background="#238636" Foreground="White" BorderThickness="0"/>
                <Button x:Name="BtnUseAsIcon" Content="Usar como icono" Padding="10,4" Click="BtnUseAsIcon_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#30363d"/>
                <Button x:Name="BtnTransformToTile" Content="Transformar en Tile…" Padding="10,4" Margin="8,0,0,0" Click="BtnTransformToTile_OnClick" Background="#21262d" Foreground="#e6edf3" BorderBrush="#30363d" ToolTip="Guarda el PNG y abre el Editor de Tiles con esta imagen"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#21262d" Padding="8" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                <StackPanel>
                    <TextBlock Text="Capas" FontWeight="SemiBold" Foreground="#e6edf3" Margin="0,0,0,8"/>
                    <ListBox x:Name="LayersList" MinHeight="120" SelectionChanged="LayersList_SelectionChanged"
                             Background="#161b22" Foreground="#e6edf3" BorderThickness="0"/>
                    <CheckBox x:Name="ChkLayerVisible" Content="Visible" Foreground="#e6edf3" Margin="0,6,0,0" Checked="ChkLayerVisible_Changed" Unchecked="ChkLayerVisible_Changed"/>
                    <Button x:Name="BtnAddLayer" Content="+ Capa" Margin="0,8,0,4" Padding="8,4" Click="BtnAddLayer_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#30363d"/>
                    <Button x:Name="BtnRemoveLayer" Content="− Capa" Margin="0,0,0,0" Padding="8,4" Click="BtnRemoveLayer_OnClick" Background="#21262d" Foreground="#f85149" BorderBrush="#30363d"/>
                </StackPanel>
            </Border>
            <local:DrawingCanvasControl x:Name="DrawingCanvas" Grid.Column="1" Margin="8"/>
        </Grid>
    </Grid>
</UserControl>
