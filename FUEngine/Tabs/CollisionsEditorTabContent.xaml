<UserControl x:Class="FUEngine.CollisionsEditorTabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FUEngine"
             Background="#161b22">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#21262d" Padding="8,6" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="TxtPath" Text="Editor de colisiones — Sin archivo" VerticalAlignment="Center" Foreground="#8b949e" Margin="0,0,16,0"/>
                <Button x:Name="BtnOpen" Content="Abrir imagen" Padding="10,4" Margin="0,0,12,0" Click="BtnOpen_OnClick" Background="#21262d" Foreground="#58a6ff" BorderBrush="#30363d"/>
                <RadioButton x:Name="RbBox" Content="Box" GroupName="Tool" IsChecked="True" Foreground="#e6edf3" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Separator Margin="8,0" Width="2" Background="#30363d"/>
                <TextBlock Text="Capa:" VerticalAlignment="Center" Foreground="#e6edf3" Margin="0,0,6,0"/>
                <ComboBox x:Name="CmbLayer" Width="120" Margin="0,0,16,0" SelectionChanged="CmbLayer_SelectionChanged">
                    <ComboBoxItem Content="Solid" Tag="Solid"/>
                    <ComboBoxItem Content="Trigger" Tag="Trigger"/>
                    <ComboBoxItem Content="One-Way" Tag="OneWay"/>
                </ComboBox>
                <Button x:Name="BtnSave" Content="Guardar" Padding="10,4" Click="BtnSave_OnClick" Background="#238636" Foreground="White" BorderThickness="0"/>
                <Button x:Name="BtnDeleteShape" Content="Eliminar forma" Padding="10,4" Margin="8,0,0,0" Click="BtnDeleteShape_OnClick" Background="#21262d" Foreground="#f85149" BorderBrush="#30363d"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#21262d" Padding="8" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                <StackPanel>
                    <TextBlock Text="Formas de colisión" FontWeight="SemiBold" Foreground="#e6edf3" Margin="0,0,0,8"/>
                    <ListBox x:Name="ShapesList" MinHeight="120" SelectionChanged="ShapesList_SelectionChanged"
                             Background="#161b22" Foreground="#e6edf3" BorderThickness="0"/>
                </StackPanel>
            </Border>
            <local:CollisionShapesCanvasControl x:Name="ShapesCanvas" Grid.Column="1" Margin="8"/>
        </Grid>
    </Grid>
</UserControl>
