# Build y salidas locales (el motor se compila de nuevo con dotnet build)
bin/
obj/
.vs/
publish/

# Scripts personales del desarrollador (publicar.bat, etc.) — no subir al remoto
tools/

# Artefactos de release locales (carpetas de prueba, instaladores viejos, etc.)
dist/
# InstalarFUEngine.exe en la raíz se versiona con Git LFS (.gitattributes), no ignorar
# Layout antiguo (carpeta con DLL del runtime); el script la borra al regenerar
/InstalarFUEngine/
# Artefactos viejos del instalador (no deben quedar en disco; por si acaso)
**/EnginePayload.zip
**/fue_motor.pack
/FUEngine_Setup*.exe
/FUEngine-Setup*.exe
# Nunca copiar instaladores dentro del proyecto del editor (solo FUEngine.exe ahí)
FUEngine/FUEngine_Setup*.exe
# Salida completa de dotnet publish del instalador
FUEngine.Installer/publish/
*.user
*.suo
*_wpftmp*

# NuGet
packages/
*.nupkg

# Caché de streaming de chunks en Play (por proyecto)
**/.fue_play_chunk_cache/

# Logs y temporales
*.log
*.tmp
.DS_Store
Thumbs.db

# Cursor e instrucciones solo locales
.cursor/
instruccionescursor.md

# IDEs (configuración local; no hace falta para compilar el motor)
.idea/
.vscode/
*.DotSettings.user
_ReSharper.Caches/

# Pruebas y cobertura (si se añaden más adelante)
TestResults/
[Tt]est[Rr]esult*/
*.coverage
*.coveragexml

# Claves / secretos locales (nunca en el repo)
*.pfx
*.snk
.env
.env.local

# Restos de merge y copias de seguridad
*.orig
*.rej
*~
